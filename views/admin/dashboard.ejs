<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Admin Panel - Dashboard</title>
    <!-- Added Tailwind CSS CDN -->
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="">
    <!-- Converted all styling to Tailwind classes -->
    <!-- <div class="text-gray-500 text-sm mb-4 pl-2">Admin Panel</div> -->
    
    <div class="max-w-[1400px] mx-auto bg-white flex min-h-[600px] shadow-lg">
        <!-- Sidebar -->
        <aside class="w-[200px] bg-gray-50 p-8 flex flex-col">
            <div class="text-2xl font-bold mb-10 text-black">Headshield</div>
            
            <ul class="flex-grow space-y-2">
                <li>
                    <a href="#" class="block px-4 py-3 rounded-md text-sm text-white bg-blue-500 font-medium">Dashboard</a>
                </li>
                <li>
                    <a href="#" class="block px-4 py-3 rounded-md text-sm text-gray-700 hover:bg-gray-200 transition">Products</a>
                </li>
                <li>
                    <a href="#" class="block px-4 py-3 rounded-md text-sm text-gray-700 hover:bg-gray-200 transition">Order Lists</a>
                </li>
                <li>
                    <a href="/admin/users" class="block px-4 py-3 rounded-md text-sm text-gray-700 hover:bg-gray-200 transition">Users</a>
                </li>
                <li>
                    <a href="#" class="block px-4 py-3 rounded-md text-sm text-gray-700 hover:bg-gray-200 transition">Sales Report</a>
                </li>
                <li>
                    <a href="#" class="block px-4 py-3 rounded-md text-sm text-gray-700 hover:bg-gray-200 transition">Coupons</a>
                </li>
                <li>
                    <a href="#" class="block px-4 py-3 rounded-md text-sm text-gray-700 hover:bg-gray-200 transition">Category</a>
                </li>
                <li>
                    <a href="#" class="block px-4 py-3 rounded-md text-sm text-gray-700 hover:bg-gray-200 transition">Banners</a>
                </li>
                <li>
                    <a href="#" class="block px-4 py-3 rounded-md text-sm text-gray-700 hover:bg-gray-200 transition">Offers</a>
                </li>
            </ul>

            <div class="mt-auto space-y-2">
                <a href="#" class="block px-4 py-3 rounded-md text-sm text-gray-700 hover:bg-gray-200 transition">Settings</a>
                <a href="#" class="block px-4 py-3 rounded-md text-sm text-gray-700 hover:bg-gray-200 transition">Logout</a>
            </div>
        </aside>
        

        <!-- Main Content -->
        <main class="flex-1 p-10">
            <!-- Header -->
            <div class="flex justify-between items-center mb-8">
                <h1 class="text-3xl font-semibold text-black">Dashboard</h1>
                <div class="relative">
                    <span class="absolute left-3 top-1/2 -translate-y-1/2 text-gray-400">🔍</span>
                    <input type="text" class="w-64 pl-10 pr-4 py-2 border border-gray-200 rounded-md text-sm focus:outline-none focus:border-blue-400" placeholder="Search">
                </div>
            </div>

            <!-- Stats Grid -->
            <div class="grid grid-cols-3 gap-5 mb-8">
                <!-- Total User Card -->
                <div class="bg-white border border-gray-200 rounded-lg p-6 flex justify-between items-start">
                    <div class="flex-1">
                        <div class="text-sm text-gray-500 mb-2">Total User</div>
                        <div class="text-3xl font-bold text-black mb-3">30,611</div>
                        <div class="flex items-center gap-1 text-xs text-teal-500">
                            <span>↗</span>
                            <span>8.5% Up from last month</span>
                        </div>
                    </div>
                    <div class="w-12 h-12 rounded-xl bg-blue-50 flex items-center justify-center text-2xl">👥</div>
                </div>

                <!-- Total Order Card -->
                <div class="bg-white border border-gray-200 rounded-lg p-6 flex justify-between items-start">
                    <div class="flex-1">
                        <div class="text-sm text-gray-500 mb-2">Total Order</div>
                        <div class="text-3xl font-bold text-black mb-3">11293</div>
                        <div class="flex items-center gap-1 text-xs text-teal-500">
                            <span>↗</span>
                            <span>1.3% Up from last month</span>
                        </div>
                    </div>
                    <div class="w-12 h-12 rounded-xl bg-orange-50 flex items-center justify-center text-2xl">📦</div>
                </div>

                <!-- Total Sales Card -->
                <div class="bg-white border border-gray-200 rounded-lg p-6 flex justify-between items-start">
                    <div class="flex-1">
                        <div class="text-sm text-gray-500 mb-2">Total Sales</div>
                        <div class="text-3xl font-bold text-black mb-3">$59,999</div>
                        <div class="flex items-center gap-1 text-xs text-red-500">
                            <span>↘</span>
                            <span>4.3% Down from last month</span>
                        </div>
                    </div>
                    <div class="w-12 h-12 rounded-xl bg-teal-50 flex items-center justify-center text-2xl">📊</div>
                </div>
            </div>

            <!-- Chart Section -->
            <div class="bg-white border border-gray-200 rounded-lg p-6 mb-8">
                <div class="flex justify-between items-center mb-8">
                    <h2 class="text-lg font-semibold text-black">Sales Details</h2>
                    <div class="flex gap-3">
                        <select class="px-4 py-2 border border-gray-200 rounded-md text-sm text-gray-600 bg-white cursor-pointer focus:outline-none">
                            <option>Today</option>
                            <option>This Week</option>
                            <option>This Month</option>
                        </select>
                        <select class="px-4 py-2 border border-gray-200 rounded-md text-sm text-gray-600 bg-white cursor-pointer focus:outline-none">
                            <option>October</option>
                            <option>November</option>
                            <option>December</option>
                        </select>
                    </div>
                </div>
                <div class="h-64 relative">
                    <svg class="w-full h-full" viewBox="0 0 800 200" preserveAspectRatio="none">
                        <defs>
                            <linearGradient id="gradient" x1="0%" y1="0%" x2="0%" y2="100%">
                                <stop offset="0%" style="stop-color:#6B9BFF;stop-opacity:0.3" />
                                <stop offset="100%" style="stop-color:#6B9BFF;stop-opacity:0.05" />
                            </linearGradient>
                        </defs>
                        
                        <polyline
                            fill="url(#gradient)"
                            stroke="none"
                            points="0,150 40,140 80,120 120,110 160,105 200,125 240,115 280,95 320,50 360,90 400,85 440,80 480,95 520,70 560,140 600,130 640,100 680,110 720,95 760,80 800,85 800,200 0,200"
                        />
                        
                        <polyline
                            fill="none"
                            stroke="#4F7CFF"
                            stroke-width="2"
                            points="0,150 40,140 80,120 120,110 160,105 200,125 240,115 280,95 320,50 360,90 400,85 440,80 480,95 520,70 560,140 600,130 640,100 680,110 720,95 760,80 800,85"
                        />
                        
                        <circle cx="320" cy="50" r="4" fill="#4F7CFF" />
                    </svg>
                    <div class="absolute left-80 top-8 bg-blue-500 text-white px-3 py-1.5 rounded text-xs font-semibold pointer-events-none after:content-[''] after:absolute after:bottom-[-6px] after:left-1/2 after:-translate-x-1/2 after:border-l-[6px] after:border-r-[6px] after:border-t-[6px] after:border-l-transparent after:border-r-transparent after:border-t-blue-500">
                        10,564.77
                    </div>
                </div>
            </div>

            <!-- Table Section -->
            <div class="bg-white border border-gray-200 rounded-lg overflow-hidden">
                <table class="w-full">
                    <thead class="bg-gray-50">
                        <tr>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">ID</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">NAME</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">ADDRESS</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">DATE</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">TYPE</th>
                            <th class="px-6 py-4 text-left text-xs font-semibold text-gray-500 uppercase tracking-wider">STATUS</th>
                        </tr>
                    </thead>
                    <tbody>
                        <tr>
                            <td class="px-6 py-5 text-sm text-gray-700 border-t border-gray-100">00001</td>
                            <td class="px-6 py-5 text-sm text-gray-700 border-t border-gray-100">Abhijith TS</td>
                            <td class="px-6 py-5 text-sm text-gray-700 border-t border-gray-100">089 Kutch Green Apt. 448</td>
                            <td class="px-6 py-5 text-sm text-gray-700 border-t border-gray-100">04 dec 2025</td>
                            <td class="px-6 py-5 text-sm text-gray-700 border-t border-gray-100">Electric</td>
                            <td class="px-6 py-5 text-sm border-t border-gray-100">
                                <span class="inline-block px-4 py-1.5 rounded bg-teal-100 text-teal-700 text-xs font-medium">Completed</span>
                            </td>
                        </tr>
                        <tr>
                            <td class="px-6 py-5 text-sm text-gray-700 border-t border-gray-100">00002</td>
                            <td class="px-6 py-5 text-sm text-gray-700 border-t border-gray-100">shahan</td>
                            <td class="px-6 py-5 text-sm text-gray-700 border-t border-gray-100">979 Immanuel Ferry Suite 526</td>
                            <td class="px-6 py-5 text-sm text-gray-700 border-t border-gray-100">18 dec 2025</td>
                            <td class="px-6 py-5 text-sm text-gray-700 border-t border-gray-100">Book</td>
                            <td class="px-6 py-5 text-sm border-t border-gray-100">
                                <span class="inline-block px-4 py-1.5 rounded bg-purple-100 text-purple-700 text-xs font-medium">Processing</span>
                            </td>
                        </tr>
                        <tr>
                            <td class="px-6 py-5 text-sm text-gray-700 border-t border-gray-100">00003</td>
                            <td class="px-6 py-5 text-sm text-gray-700 border-t border-gray-100">Aswin kl</td>
                            <td class="px-6 py-5 text-sm text-gray-700 border-t border-gray-100">8587 Frida Ports</td>
                            <td class="px-6 py-5 text-sm text-gray-700 border-t border-gray-100">03 dec 2025</td>
                            <td class="px-6 py-5 text-sm text-gray-700 border-t border-gray-100">Medicine</td>
                            <td class="px-6 py-5 text-sm border-t border-gray-100">
                                <span class="inline-block px-4 py-1.5 rounded bg-red-100 text-red-600 text-xs font-medium">Rejected</span>
                            </td>
                        </tr>
                    </tbody>
                </table>
            </div>
        </main>
    </div>
</body>
</html>
