<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Admin OTP Verification</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-900 text-white min-h-screen flex items-center justify-center">

<div class="bg-gray-800 p-8 rounded-lg w-full max-w-md shadow-lg">

  <h2 class="text-2xl font-bold text-center mb-6">Verify OTP</h2>

  <!-- ERROR -->
  <% if (error) { %>
    <p class="text-red-400 text-center mb-4"><%= error %></p>
  <% } %>

  <!-- SUCCESS -->
  <% if (message) { %>
    <p class="text-green-400 text-center mb-4"><%= message %></p>
  <% } %>

  <!-- FORM -->
  <form method="POST" action="/admin/verify-otp" id="otpForm">

    <!-- OTP INPUT -->
    <div class="mb-4">
      <label class="block text-sm mb-2">Enter OTP</label>
      <input type="text" name="otp" id="otp"
        maxlength="6"
        required
        class="w-full px-4 py-3 bg-gray-700 border border-gray-600 rounded focus:outline-none focus:border-orange-500"
        placeholder="Enter 6-digit OTP">

      <p id="otpError" class="text-red-400 text-sm mt-1 hidden"></p>
    </div>

    <!-- SUBMIT -->
    <button type="submit"
      class="w-full bg-orange-500 py-3 rounded hover:bg-orange-600">
      Verify OTP
    </button>

  </form>

  <!-- RESEND -->
  <div class="mt-4 text-center">
    <button onclick="resendOtp()"
      id="resendBtn"
      class="text-gray-400 hover:text-white"
      disabled>
      Resend OTP
    </button>

    <p id="timerText" class="text-sm mt-2">
      Resend in <span id="countdown">60</span>s
    </p>
  </div>

</div>

<script>
const form = document.getElementById("otpForm");
const otpInput = document.getElementById("otp");
const errorEl = document.getElementById("otpError");

// VALIDATION
form.addEventListener("submit", function(e) {
  let valid = true;

  const otp = otpInput.value.trim();

  if (!otp) {
    showError("OTP is required");
    valid = false;
  } else if (!/^[0-9]{6}$/.test(otp)) {
    showError("Enter valid 6-digit OTP");
    valid = false;
  } else {
    clearError();
  }

  if (!valid) e.preventDefault();
});

function showError(msg) {
  errorEl.textContent = msg;
  errorEl.classList.remove("hidden");
  otpInput.classList.add("border-red-500");
}

function clearError() {
  errorEl.classList.add("hidden");
  otpInput.classList.remove("border-red-500");
}

// ONLY DIGITS
otpInput.addEventListener("input", function() {
  this.value = this.value.replace(/[^0-9]/g, '');
});

// TIMER
let secs = 60;
const countEl = document.getElementById("countdown");
const resendBtn = document.getElementById("resendBtn");
const timerEl = document.getElementById("timerText");

const interval = setInterval(() => {
  secs--;
  countEl.textContent = secs;

  if (secs <= 0) {
    clearInterval(interval);
    timerEl.style.display = "none";
    resendBtn.disabled = false;
  }
}, 1000);

// RESEND
async function resendOtp() {
  try {
    const res = await fetch("/admin/resend-otp", {
      method: "POST"
    });

    const data = await res.json();

    if (data.success) {
      alert("OTP resent!");
      location.reload();
    } else {
      alert(data.message || "Failed to resend OTP");
    }
  } catch {
    alert("Error resending OTP");
  }
}
</script>

</body>
</html>