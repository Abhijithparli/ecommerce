<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Admin OTP - Headshield</title>

<script src="https://cdn.tailwindcss.com"></script>

<style>
body {
  background-image: url('/img/bgsignup.jpg');
  background-size: cover;
  background-position: center;
}
.overlay {
  position: fixed;
  inset: 0;
  background: rgba(0,0,0,0.75);
}
.glass {
  background: rgba(0,0,0,0.65);
  backdrop-filter: blur(16px);
  border: 1px solid rgba(255,255,255,0.08);
}
</style>
</head>

<body class="min-h-screen flex items-center justify-center text-white">

<div class="overlay"></div>

<div class="relative z-10 w-full max-w-md px-4">

  <div class="glass rounded-xl p-10 shadow-2xl">

    <h2 class="text-2xl text-center font-semibold mb-3">Admin OTP Verification</h2>

    <p class="text-gray-400 text-sm text-center mb-6">
      OTP sent to <span class="text-orange-400"><%= email %></span>
    </p>

    <!-- ERROR -->
    <% if (error) { %>
      <div class="bg-red-500/20 border border-red-500 text-red-300 p-3 rounded mb-5 text-center text-sm">
        <%= error %>
      </div>
    <% } %>

    <!-- SUCCESS -->
    <% if (success) { %>
      <div class="bg-green-500/20 border border-green-500 text-green-300 p-3 rounded mb-5 text-center text-sm">
        <%= success %>
      </div>
    <% } %>

    <!-- FORM -->
    <form method="POST" action="/admin/verify-otp">

      <input type="hidden" name="email" value="<%= email %>">

      <input 
        type="text" 
        name="otp"
        maxlength="6"
        placeholder="Enter OTP"
        required
        class="w-full px-4 py-3 mb-5 rounded-md bg-gray-900/60 border border-gray-600 text-center tracking-[10px] text-white"
      >

      <button 
        type="submit"
        class="w-full py-3 rounded-md font-semibold bg-gradient-to-r from-orange-500 to-orange-600"
      >
        Verify OTP
      </button>

    </form>

    <!-- RESEND -->
    <div class="mt-6 text-center">
      <button onclick="resendOTP()" id="resend-btn"
        class="text-orange-500 hover:text-orange-400">
        Resend OTP
      </button>
      <p class="text-gray-400 text-sm mt-2" id="timer"></p>
    </div>

  </div>
</div>

<script>
let seconds = 60;

function startTimer() {
  const timer = document.getElementById('timer');
  const btn = document.getElementById('resend-btn');

  btn.disabled = true;

  const interval = setInterval(() => {
    seconds--;
    timer.textContent = `Resend in ${seconds}s`;

    if (seconds <= 0) {
      clearInterval(interval);
      btn.disabled = false;
      timer.textContent = "";
    }
  }, 1000);
}

async function resendOTP() {
  await fetch('/admin/resend-otp', { method: 'POST' });
  seconds = 60;
  startTimer();
}

startTimer();
</script>

</body>
</html>