<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Edit Product</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-900 text-white min-h-screen p-8">

<div class="max-w-5xl mx-auto bg-gray-800 rounded-2xl p-8">

  <h1 class="text-3xl font-bold mb-8">
    Edit Product
  </h1>

  <% if (error) { %>

    <div class="bg-red-500/20 border border-red-500 text-red-300 px-4 py-3 rounded mb-4">
      <%= error %>
    </div>

  <% } %>

  <form
    action="/admin/products/<%= product._id %>/edit"
    method="POST"
    enctype="multipart/form-data"
    class="grid grid-cols-1 md:grid-cols-2 gap-6"
  >

    <!-- NAME -->
    <div>

      <label class="block mb-2">
        Product Name
      </label>

      <input
        type="text"
        name="name"
        value="<%= product.name %>"
        class="w-full px-4 py-3 rounded bg-gray-700"
      >

    </div>

    <!-- BRAND -->
    <div>

      <label class="block mb-2">
        Brand
      </label>

      <input
        type="text"
        name="brand"
        value="<%= product.brand %>"
        class="w-full px-4 py-3 rounded bg-gray-700"
      >

    </div>

    <!-- CATEGORY -->
    <div>

      <label class="block mb-2">
        Category
      </label>

      <select
        name="category"
        class="w-full px-4 py-3 rounded bg-gray-700"
      >

        <% categories.forEach(category => { %>

          <option
            value="<%= category._id %>"

            <%= product.category.toString() === category._id.toString()
              ? "selected"
              : ""
            %>
          >
            <%= category.name %>
          </option>

        <% }) %>

      </select>

    </div>

    <!-- REGULAR PRICE -->
    <div>

      <label class="block mb-2">
        Regular Price
      </label>

      <input
        type="number"
        name="regularPrice"
        value="<%= product.regularPrice %>"
        class="w-full px-4 py-3 rounded bg-gray-700"
      >

    </div>

    <!-- SALE PRICE -->
    <div>

      <label class="block mb-2">
        Sale Price
      </label>

      <input
        type="number"
        name="salePrice"
        value="<%= product.salePrice %>"
        class="w-full px-4 py-3 rounded bg-gray-700"
      >

    </div>

    <!-- QUANTITY -->
    <div>

      <label class="block mb-2">
        Quantity
      </label>

      <input
        type="number"
        name="quantity"
        value="<%= product.quantity %>"
        class="w-full px-4 py-3 rounded bg-gray-700"
      >

    </div>

    <!-- DESCRIPTION -->
    <div class="md:col-span-2">

      <label class="block mb-2">
        Description
      </label>

      <textarea
        name="description"
        rows="4"
        class="w-full px-4 py-3 rounded bg-gray-700"
      ><%= product.description %></textarea>

    </div>

    <!-- CURRENT IMAGES -->
    <div class="md:col-span-2">

      <label class="block mb-2">
        Current Images
      </label>

      <div class="flex gap-3 flex-wrap">

        <% product.images.forEach(image => { %>

          <img
            src="<%= image %>"
            class="w-24 h-24 object-cover rounded"
          >

        <% }) %>

      </div>

    </div>

    <!-- NEW IMAGES -->
    <div class="md:col-span-2">

      <label class="block mb-2">
        Upload New Images
      </label>

      <input
        type="file"
        name="images"
        multiple
        class="w-full px-4 py-3 rounded bg-gray-700"
      >

    </div>

    <!-- BUTTON -->
    <div class="md:col-span-2">

      <button
        class="bg-orange-500 hover:bg-orange-600 px-8 py-3 rounded"
      >
        Update Product
      </button>

    </div>

  </form>

</div>

</body>
</html> 