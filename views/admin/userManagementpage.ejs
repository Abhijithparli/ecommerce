<!-- views/admin/userManagementpage.ejs -->
<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <meta name="viewport" content="width=device-width, initial-scale=1.0">
  <title>Users - Headshield</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <script src="https://cdn.jsdelivr.net/npm/sweetalert2@11"></script>
</head>

<body class="bg-gray-50 font-sans">
<div class="flex min-h-screen">

  <!-- ✅ Sidebar partial -->
<%- include('./partials/sidebar', { currentPage: 'dashboard' }) %>

  <!-- Main -->
  <main class="flex-1 ml-64">

    <!-- Header -->
    <header class="bg-white border-b px-8 py-4">
      <form method="GET" action="/admin/users" id="searchForm">
        <div class="relative w-80">
          <input
            type="text"
            name="search"
            id="searchInput"
            value="<%= searchQuery || '' %>"
            placeholder="Search user"
            class="border px-4 py-2 rounded-lg w-full pr-10"
            oninput="handleSearch(this)"
          />
          <button
            type="button"
            id="clearBtn"
            onclick="clearSearch()"
            class="absolute right-3 top-1/2 -translate-y-1/2 text-gray-400 <%= searchQuery ? '' : 'hidden' %>">
            ✕
          </button>
        </div>
      </form>
    </header>

    <!-- Content -->
    <div class="p-8">

      <!-- Filter -->
      <form method="GET" action="/admin/users" class="mb-6">
        <select name="status" onchange="this.form.submit()" class="px-4 py-2 border rounded-lg">
          <option value="all"       <%= filterStatus === 'all'       ? 'selected' : '' %>>All</option>
          <option value="blocked"   <%= filterStatus === 'blocked'   ? 'selected' : '' %>>Blocked</option>
          <option value="unblocked" <%= filterStatus === 'unblocked' ? 'selected' : '' %>>Active</option>
        </select>
      </form>

      <!-- Table -->
      <div class="bg-white rounded-xl shadow overflow-hidden">

        <div class="bg-indigo-600 text-white grid grid-cols-5 px-6 py-4 font-medium">
          <div>S.No</div>
          <div>Name</div>
          <div>Email</div>
          <div>Action</div>
          <div>Status</div>
        </div>

        <% if (users.length === 0) { %>
          <div class="px-6 py-10 text-center text-gray-400">No users found.</div>
        <% } %>

        <% users.forEach((data, index) => { %>
        <div class="grid grid-cols-5 px-6 py-5 border-t items-center">
          <div><%= (currentPage - 1) * limit + index + 1 %></div>
          <div><%= data.name %></div>
          <div><%= data.email %></div>

          <!-- Block / Unblock Button -->
          <div>
            <button
              type="button"
              class="px-3 py-1 rounded-md text-sm font-medium
              <%= data.isBlocked ? 'bg-green-100 text-green-700' : 'bg-red-100 text-red-700' %>"
              onclick="<%= data.isBlocked ? `confirmUnblock('${data._id}')` : `confirmBlock('${data._id}')` %>">
              <%= data.isBlocked ? 'Unblock' : 'Block' %>
            </button>
          </div>

          <!-- Status -->
          <div class="<%= data.isBlocked ? 'text-red-600' : 'text-green-600' %>">
            <%= data.isBlocked ? 'Blocked' : 'Active' %>
          </div>
        </div>
        <% }) %>

      </div>
    </div>

    <!-- Pagination -->
    <div class="flex justify-center items-center gap-2 mt-4 mb-8">

      <% if (currentPage > 1) { %>
        <a href="/admin/users?page=<%= currentPage - 1 %>&limit=<%= limit %>&status=<%= filterStatus %>&search=<%= searchQuery %>"
           class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
          Previous
        </a>
      <% } %>

      <% for (let i = 1; i <= totalPages; i++) { %>
        <a href="/admin/users?page=<%= i %>&limit=<%= limit %>&status=<%= filterStatus %>&search=<%= searchQuery %>"
           class="w-10 h-10 flex items-center justify-center rounded-lg
           <%= i === currentPage ? 'bg-black text-white' : 'bg-gray-200 text-gray-700' %>">
          <%= i %>
        </a>
      <% } %>

      <% if (currentPage < totalPages) { %>
        <a href="/admin/users?page=<%= currentPage + 1 %>&limit=<%= limit %>&status=<%= filterStatus %>&search=<%= searchQuery %>"
           class="px-4 py-2 border border-gray-300 rounded-lg text-gray-700 hover:bg-gray-50">
          Next
        </a>
      <% } %>

    </div>

  </main>
</div>

<script>
function confirmBlock(userId) {
  Swal.fire({
    title: "Are you sure?",
    text: "You want to block this user",
    icon: "warning",
    showCancelButton: true,
    confirmButtonText: "Yes, block",
  }).then(async (result) => {
    if (!result.isConfirmed) return;
    const res  = await fetch(`/admin/users/block/${userId}`, { method: "POST" });
    const data = await res.json();
    if (data.success) {
      Swal.fire("Blocked!", "User has been blocked.", "success").then(() => location.reload());
    } else {
      Swal.fire("Error", data.message || "Failed", "error");
    }
  });
}

function confirmUnblock(userId) {
  Swal.fire({
    title: "Are you sure?",
    text: "You want to unblock this user",
    icon: "warning",
    showCancelButton: true,
    confirmButtonText: "Yes, unblock",
  }).then(async (result) => {
    if (!result.isConfirmed) return;
    const res  = await fetch(`/admin/users/unblock/${userId}`, { method: "POST" });
    const data = await res.json();
    if (data.success) {
      Swal.fire("Unblocked!", "User has been unblocked.", "success").then(() => location.reload());
    } else {
      Swal.fire("Error", data.message || "Failed", "error");
    }
  });
}

function handleSearch(input) {
  const clearBtn = document.getElementById("clearBtn");
  if (input.value.trim() === "") {
    clearBtn.classList.add("hidden");
    window.location.href = "/admin/users";
  } else {
    clearBtn.classList.remove("hidden");
  }
}

function clearSearch() {
  window.location.href = "/admin/users";
}
</script>

</body>
</html>
