<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Forgot Password - Headshield</title>

<script src="https://cdn.tailwindcss.com"></script>

<style>
@import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=DM+Sans:wght@300;400;500&display=swap');

* { font-family: 'DM Sans', sans-serif; }
h1, h2 { font-family: 'Rajdhani', sans-serif; }


.bg-scene {
  position: relative;
  background-image: url('/img/bgsignup.jpg');
  background-size: cover;
  background-position: center;
}

.bg-overlay {
  position: absolute;
  inset: 0;
  background: rgba(0,0,0,0.75);
}

/* Glass effect */
.glass {
  background: rgba(0,0,0,0.6);
  backdrop-filter: blur(18px);
  border: 1px solid rgba(255,255,255,0.08);
}

/* Button */
.btn-primary {
  background: linear-gradient(135deg, #f97316, #ea580c);
  transition: 0.3s;
}
.btn-primary:hover {
  transform: translateY(-2px);
  box-shadow: 0 8px 20px rgba(249,115,22,0.35);
}
</style>
</head>

<body class="bg-scene min-h-screen flex items-center justify-center text-white">

<!-- Overlay -->
<div class="bg-overlay"></div>

<div class="relative z-10 w-full max-w-md px-4">

  <div class="glass rounded-xl p-10 shadow-2xl">

    <h2 class="text-2xl text-center font-semibold mb-2">Forgot Password</h2>

    <p class="text-gray-400 text-sm text-center mb-8">
      Enter your email and we'll send reset instructions.
    </p>

    <!-- Messages -->
    <% if (typeof message !== 'undefined' && message) { %>
      <div class="bg-green-500/20 border border-green-500/50 text-green-300 p-3 rounded-lg mb-5 text-sm text-center">
        <%= message %>
      </div>
    <% } %>

    <% if (typeof error !== 'undefined' && error) { %>
      <div class="bg-red-500/20 border border-red-500/50 text-red-300 p-3 rounded-lg mb-5 text-sm text-center">
        <%= error %>
      </div>
    <% } %>

<!-- <%= typeof formAction !== 'undefined' ? formAction : '/forgot-password' %> -->

      <label class="block text-sm text-gray-300 mb-2">Email Address</label>

      <input 
        type="email" 
        name="email"
        placeholder="yourname@email.com"
        required
        class="w-full px-4 py-3 rounded-lg bg-gray-900/70 border border-gray-600 text-white placeholder-gray-500 outline-none mb-4"
      >

      <button type="submit" class="btn-primary w-full py-3 rounded-lg font-semibold">
        Send Reset Link
      </button>

    </form>

    <div class="flex justify-between mt-6 text-sm">
      <a href="/login" class="text-orange-400 hover:text-orange-300">← Back to Login</a>
      <a href="/signup" class="text-gray-400 hover:text-white">Create Account</a>
    </div>

  </div>
</div>

</body>
</html>