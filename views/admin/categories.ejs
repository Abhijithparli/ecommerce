<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Category Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-900 text-white min-h-screen p-8">

<div class="max-w-6xl mx-auto">

  <!-- HEADER -->
  <div class="flex justify-between items-center mb-8">
    <h1 class="text-3xl font-bold">
                                                                                                              Category Management
    </h1>
  </div>
  <!-- SEARCH BAR -->
<div class="bg-gray-800 rounded-xl p-5 mb-6">

  <form
    action="/admin/categories"
    method="GET"
    class="flex gap-3"
  >

    <input
      type="text"
      name="search"
      value="<%= search %>"
      placeholder="Search category..."
      class="flex-1 px-4 py-3 rounded-lg bg-gray-700 border border-gray-600 focus:outline-none"
    >

    <!-- SEARCH BUTTON -->
    <button
      class="bg-orange-500 hover:bg-orange-600 px-5 rounded-lg"
    >
      Search
    </button>

    <!-- CLEAR BUTTON -->
    <a
      href="/admin/categories"
      class="bg-gray-600 hover:bg-gray-500 px-5 py-3 rounded-lg"
    >
      Clear
    </a>

  </form>

</div>


  <!-- SUCCESS MESSAGE -->
  <% if (success) { %>
    <div class="bg-green-500/20 border border-green-500 text-green-300 px-4 py-3 rounded mb-4">
      <%= success %>
    </div>
  <% } %>

  <!-- ERROR MESSAGE -->
  <% if (error) { %>
    <div class="bg-red-500/20 border border-red-500 text-red-300 px-4 py-3 rounded mb-4">
      <%= error %>
    </div>
  <% } %>


  <!-- ADD CATEGORY FORM -->
  <div class="bg-gray-800 rounded-xl p-6 mb-8 shadow-lg">

    <h2 class="text-xl font-semibold mb-4">
      Add New Category
    </h2>

    <form action="/admin/categories/add" method="POST">

      <!-- CATEGORY NAME -->
      <div class="mb-4">
        <label class="block mb-2 text-sm">Category Name</label>

        <input
          type="text"
          name="name"
          placeholder="Enter category name"
          class="w-full px-4 py-3 rounded-lg bg-gray-700 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-orange-500"
          required
        >
      </div>

      <!-- DESCRIPTION -->
      <div class="mb-4">
        <label class="block mb-2 text-sm">Description</label>

        <textarea
          name="description"
          rows="3"
          placeholder="Enter category description"
          class="w-full px-4 py-3 rounded-lg bg-gray-700 border border-gray-600 focus:outline-none focus:ring-2 focus:ring-orange-500"
        ></textarea>
      </div>

      <!-- BUTTON -->
      <button
        class="bg-orange-500 hover:bg-orange-600 transition px-6 py-3 rounded-lg font-semibold"
      >
        Add Category
      </button>

    </form>
  </div>


  <!-- CATEGORY TABLE -->
  <div class="bg-gray-800 rounded-xl shadow-lg overflow-hidden">

    <table class="w-full">

      <!-- TABLE HEAD -->
      <thead class="bg-gray-700 text-left">
        <tr>
          <th class="px-6 py-4">Category</th>
          <th class="px-6 py-4">Description</th>
          <th class="px-6 py-4">Created</th>
          <th class="px-6 py-4 text-center">Actions</th>
        </tr>
      </thead>

      <!-- TABLE BODY -->
      <tbody>

      <% if (categories.length > 0) { %>

        <% categories.forEach(category => { %>

          <tr class="border-t border-gray-700 hover:bg-gray-700/40">

            <!-- NAME -->
            <td class="px-6 py-4 font-medium">
              <%= category.name %>
            </td>

            <!-- DESCRIPTION -->
            <td class="px-6 py-4 text-gray-300">
              <%= category.description || "No description" %>
            </td>

            <!-- DATE -->
            <td class="px-6 py-4 text-sm text-gray-400">
              <%= category.createdAt.toDateString() %>
            </td>

            <!-- ACTIONS -->
            <td class="px-6 py-4">

              <div class="flex justify-center gap-3">

                <!-- EDIT FORM -->
<a
  href="/admin/categories/<%= category._id %>/edit"
  class="bg-yellow-500 hover:bg-yellow-600 px-3 py-1 rounded"
>
  Edit
</a>

                <!-- DELETE -->
<form
  action="/admin/categories/<%= category._id %>/delete"
  method="POST"
  class="deleteForm"
>

  <button
    type="button"
    onclick="openDeleteModal(this)"
    class="bg-red-500 hover:bg-red-600 px-3 py-1 rounded"
  >
    Delete
  </button>

</form>

              </div>

            </td>

          </tr>

        <% }) %>

      <% } else { %>

        <tr>
          <td colspan="4" class="text-center py-8 text-gray-400">
            No categories found
          </td>
        </tr>

      <% } %>

      </tbody>

    </table>
    <!-- PAGINATION -->
<div class="flex justify-center items-center gap-3 py-6">

  <!-- PREVIOUS -->
  <% if (currentPage > 1) { %>

    <a
      href="/admin/categories?page=<%= currentPage - 1 %>&search=<%= search %>"
      class="bg-gray-700 hover:bg-gray-600 px-4 py-2 rounded"
    >
      Prev
    </a>

  <% } %>

  <!-- PAGE NUMBERS -->
  <% for(let i = 1; i <= totalPages; i++) { %>

    <a
      href="/admin/categories?page=<%= i %>&search=<%= search %>"
      class="
        px-4 py-2 rounded
        <%= currentPage === i
          ? 'bg-orange-500 text-white'
          : 'bg-gray-700 hover:bg-gray-600'
        %>
      "
    >
      <%= i %>
    </a>

  <% } %>

  <!-- NEXT -->
  <% if (currentPage < totalPages) { %>

    <a
      href="/admin/categories?page=<%= currentPage + 1 %>&search=<%= search %>"
      class="bg-gray-700 hover:bg-gray-600 px-4 py-2 rounded"
    >
      Next
    </a>

  <% } %>

</div>

  </div>

</div>

<!-- DELETE MODAL -->
<div
  id="deleteModal"
  class="fixed inset-0 bg-black/60 hidden items-center justify-center z-50"
>

  <div class="bg-gray-800 w-full max-w-md rounded-2xl p-6 shadow-2xl">

    <h2 class="text-xl font-bold mb-3 text-white">
      Delete Category
    </h2>

    <p class="text-gray-300 mb-6">
      Are you sure you want to delete this category?
    </p>

    <div class="flex justify-end gap-3">

      <button
        onclick="closeDeleteModal()"
        class="px-5 py-2 rounded bg-gray-600 hover:bg-gray-500"
      >
        Cancel
      </button>

      <button
        id="confirmDeleteBtn"
        class="px-5 py-2 rounded bg-red-500 hover:bg-red-600"
      >
        Delete
      </button>

    </div>

  </div>

</div>
<script>

let selectedForm = null;

function openDeleteModal(button) {

  selectedForm = button.closest("form");

  const modal = document.getElementById("deleteModal");

  modal.classList.remove("hidden");
  modal.classList.add("flex");
}

function closeDeleteModal() {

  const modal = document.getElementById("deleteModal");

  modal.classList.add("hidden");
  modal.classList.remove("flex");
}

document
  .getElementById("confirmDeleteBtn")
  .addEventListener("click", function () {

    if (selectedForm) {
      selectedForm.submit();
    }
  });

</script>
</body>
</html>