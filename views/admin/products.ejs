<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Product Management</title>
  <script src="https://cdn.tailwindcss.com"></script>
  <link
  rel="stylesheet"
  href="https://unpkg.com/cropperjs/dist/cropper.min.css"
/>

<script src="https://unpkg.com/cropperjs/dist/cropper.min.js"></script>
</head>

<body class="bg-gray-900 text-white min-h-screen p-8">

<div class="max-w-7xl mx-auto">

  <!-- HEADER -->
  <div class="flex justify-between items-center mb-8">

    <h1 class="text-3xl font-bold">
      Product Management
    </h1>

  </div>


  <!-- SUCCESS -->
  <% if (success) { %>

    <div class="bg-green-500/20 border border-green-500 text-green-300 px-4 py-3 rounded mb-4">
      <%= success %>
    </div>

  <% } %>


  <!-- ERROR -->
  <% if (error) { %>

    <div class="bg-red-500/20 border border-red-500 text-red-300 px-4 py-3 rounded mb-4">
      <%= error %>
    </div>

  <% } %>


  <!-- ADD PRODUCT FORM -->
  <div class="bg-gray-800 rounded-2xl p-8 mb-10 shadow-lg">

    <h2 class="text-2xl font-semibold mb-6">
      Add Product
    </h2>

    <form
      action="/admin/products/add"
      method="POST"
      enctype="multipart/form-data"
      class="grid grid-cols-1 md:grid-cols-2 gap-6"
    >

      <!-- PRODUCT NAME -->
      <div>

        <label class="block mb-2 text-sm">
          Product Name
        </label>

        <input
          type="text"
          name="name"
          placeholder="Enter product name"
          class="w-full px-4 py-3 rounded-lg bg-gray-700 border border-gray-600"
          required
        >

      </div>


      <!-- BRAND -->
      <div>

        <label class="block mb-2 text-sm">
          Brand
        </label>

        <input
          type="text"
          name="brand"
          placeholder="Enter brand"
          class="w-full px-4 py-3 rounded-lg bg-gray-700 border border-gray-600"
          required
        >

      </div>


      <!-- CATEGORY -->
      <div>

        <label class="block mb-2 text-sm">
          Category
        </label>

        <select
          name="category"
          class="w-full px-4 py-3 rounded-lg bg-gray-700 border border-gray-600"
          required
        >

          <option value="">
            Select Category
          </option>

          <% categories.forEach(category => { %>

            <option value="<%= category._id %>">
              <%= category.name %>
            </option>

          <% }) %>

        </select>

      </div>


      <!-- REGULAR PRICE -->
      <div>

        <label class="block mb-2 text-sm">
          Regular Price
        </label>

        <input
          type="number"
          name="regularPrice"
          placeholder="Enter regular price"
          class="w-full px-4 py-3 rounded-lg bg-gray-700 border border-gray-600"
          required
        >

      </div>


      <!-- SALE PRICE -->
      <div>

        <label class="block mb-2 text-sm">
          Sale Price
        </label>

        <input
          type="number"
          name="salePrice"
          placeholder="Enter sale price"
          class="w-full px-4 py-3 rounded-lg bg-gray-700 border border-gray-600"
          required
        >

      </div>


      <!-- QUANTITY -->
      <div>

        <label class="block mb-2 text-sm">
          Quantity
        </label>

        <input
          type="number"
          name="quantity"
          placeholder="Enter quantity"
          class="w-full px-4 py-3 rounded-lg bg-gray-700 border border-gray-600"
          required
        >

      </div>


      <!-- DESCRIPTION -->
      <div class="md:col-span-2">

        <label class="block mb-2 text-sm">
          Description
        </label>

        <textarea
          name="description"
          rows="4"
          placeholder="Enter product description"
          class="w-full px-4 py-3 rounded-lg bg-gray-700 border border-gray-600"
          required
        ></textarea>

      </div>


      <!-- IMAGES -->
      <div class="md:col-span-2">

        <label class="block mb-2 text-sm">
          Product Images (Minimum 3)
        </label>

        <input
          type="file"
          name="images"
          multiple
          accept="image/*"
          class="w-full px-4 py-3 rounded-lg bg-gray-700 border border-gray-600"
          required
        >
        <!-- IMAGE PREVIEW -->
<div
  id="imagePreviewContainer"
  class="flex flex-wrap gap-4 mt-4"
></div>

      </div>


      <!-- BUTTON -->
      <div class="md:col-span-2">

        <button
          class="bg-orange-500 hover:bg-orange-600 px-8 py-3 rounded-lg font-semibold"
        >
          Add Product
        </button>

      </div>

    </form>

  </div>


  <!-- PRODUCT TABLE -->
  <div class="bg-gray-800 rounded-2xl overflow-hidden shadow-lg">

    <table class="w-full">

      <!-- HEAD -->
      <thead class="bg-gray-700">

        <tr>

          <th class="px-6 py-4 text-left">
            Product
          </th>

          <th class="px-6 py-4 text-left">
            Category
          </th>

          <th class="px-6 py-4 text-left">
            Price
          </th>

          <th class="px-6 py-4 text-left">
            Quantity
          </th>

          <th class="px-6 py-4 text-left">
            Images
          </th>

          <th class="px-6 py-4 text-left">
  Actions
</th>

        </tr>

      </thead>


      <!-- BODY -->
      <tbody>

      <% if (products.length > 0) { %>

        <% products.forEach(product => { %>

          <tr class="border-t border-gray-700">

            <!-- NAME -->
            <td class="px-6 py-4">

              <div class="font-semibold">
                <%= product.name %>
              </div>

              <div class="text-sm text-gray-400">
                <%= product.brand %>
              </div>

            </td>


            <!-- CATEGORY -->
            <td class="px-6 py-4">

              <%= product.category?.name %>

            </td>


            <!-- PRICE -->
            <td class="px-6 py-4">

              ₹<%= product.salePrice %>

            </td>


            <!-- QUANTITY -->
            <td class="px-6 py-4">

              <%= product.quantity %>

            </td>


            <!-- IMAGES -->
            <td class="px-6 py-4">

              <div class="flex gap-2">

                <% product.images.forEach(image => { %>

                  <img
                    src="<%= image %>"
                    class="w-14 h-14 object-cover rounded"
                  >

                <% }) %>

              </div>

              <!-- ACTIONS -->

<td class="px-6 py-4">

  <div class="flex gap-3">

    <!-- EDIT -->
    <a
      href="/admin/products/<%= product._id %>/edit"
      class="bg-yellow-500 hover:bg-yellow-600 px-4 py-2 rounded"
    >
      Edit
    </a>

    <!-- DELETE -->
    <form
      action="/admin/products/<%= product._id %>/delete"
      method="POST"
    >

      <button
        onclick="return confirm('Delete this product?')"
        class="bg-red-500 hover:bg-red-600 px-4 py-2 rounded"
      >
        Delete
      </button>

    </form>

  </div>

</td>

          </tr>

        <% }) %>

      <% } else { %>

        <tr>

          <td colspan="5" class="text-center py-10 text-gray-400">

            No products found

          </td>

        </tr>

      <% } %>

      </tbody>

    </table>

  </div>

</div>

<!-- CROP MODAL -->
<div
  id="cropModal"
  class="fixed inset-0 bg-black/80 hidden items-center justify-center z-50"
>

  <div class="bg-gray-800 p-6 rounded-xl max-w-3xl w-full">

    <h2 class="text-2xl font-bold mb-4">
      Crop Image
    </h2>

    <div class="max-h-[500px] overflow-hidden">

      <img
        id="cropImage"
        class="max-w-full"
      >

    </div>

    <div class="flex justify-end gap-4 mt-6">

      <button
        id="cancelCrop"
        class="bg-gray-600 px-5 py-2 rounded"
      >
        Cancel
      </button>

      <button
        id="cropBtn"
        class="bg-orange-500 px-5 py-2 rounded"
      >
        Crop
      </button>

    </div>

  </div>

</div>

<script>

const imageInput = document.querySelector('input[name="images"]');

const previewContainer = document.getElementById(
  "imagePreviewContainer"
);

const cropModal = document.getElementById("cropModal");

const cropImage = document.getElementById("cropImage");

const cropBtn = document.getElementById("cropBtn");

const cancelCrop = document.getElementById("cancelCrop");

let cropper;

imageInput.addEventListener("change", function (e) {

  const files = e.target.files;

  if (!files.length) return;

  const file = files[0];

  const reader = new FileReader();

  reader.onload = function (event) {

    cropImage.src = event.target.result;

    cropModal.classList.remove("hidden");
    cropModal.classList.add("flex");

    cropper = new Cropper(cropImage, {

      aspectRatio: 1,

      viewMode: 1
    });
  };

  reader.readAsDataURL(file);
});

cropBtn.addEventListener("click", function () {

  const canvas = cropper.getCroppedCanvas({

    width: 800,
    height: 800
  });

  const image = document.createElement("img");

  image.src = canvas.toDataURL();

  image.className =
    "w-24 h-24 object-cover rounded-lg border";

  previewContainer.innerHTML = "";

  previewContainer.appendChild(image);

  cropper.destroy();

  cropModal.classList.add("hidden");
  cropModal.classList.remove("flex");
});

cancelCrop.addEventListener("click", function () {

  cropper.destroy();

  cropModal.classList.add("hidden");
  cropModal.classList.remove("flex");
});

</script>
</body>
</html>