<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Edit Profile - Headshield</title>
<script src="https://cdn.tailwindcss.com"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=DM+Sans:wght@300;400;500&display=swap');
  * { font-family: 'DM Sans', sans-serif; }
  h1, .brand { font-family: 'Rajdhani', sans-serif; }
  body { background: #0a0a0f; color: #e5e5e5; }
  .card { background: #13131a; border: 1px solid rgba(255,255,255,0.07); border-radius: 14px; }
  .topbar { background: #0d0d14; border-bottom: 1px solid rgba(255,255,255,0.06); padding: 14px 24px; display: flex; align-items: center; justify-content: space-between; }
  .input-field {
    width: 100%; padding: 11px 16px;
    background: #0d0d14; border: 1px solid rgba(255,255,255,0.1);
    border-radius: 8px; color: #e5e5e5; font-size: 14px; outline: none;
    transition: border-color 0.2s;
  }
  .input-field:focus { border-color: #f97316; box-shadow: 0 0 0 2px rgba(249,115,22,0.15); }
  .input-label { display: block; font-size: 12px; color: #9ca3af; margin-bottom: 6px; letter-spacing: 0.3px; text-transform: uppercase; }
  .btn-primary {
    background: linear-gradient(135deg, #f97316, #ea580c);
    padding: 11px 28px; border-radius: 8px; font-weight: 600; font-size: 14px;
    color: white; border: none; cursor: pointer; transition: all 0.2s;
  }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(249,115,22,0.3); }
  .btn-cancel {
    padding: 11px 28px; border-radius: 8px; font-size: 14px; color: #9ca3af;
    border: 1px solid rgba(255,255,255,0.1); background: transparent; cursor: pointer; transition: all 0.2s; text-decoration: none;
    display: inline-flex; align-items: center;
  }
  .btn-cancel:hover { border-color: rgba(255,255,255,0.2); color: #e5e5e5; }

  /* Avatar upload */
  .avatar-upload { position: relative; width: 100px; height: 100px; cursor: pointer; }
  .avatar-upload img, .avatar-initials-sm {
    width: 100px; height: 100px; border-radius: 50%;
    border: 3px solid #f97316; object-fit: cover;
  }
  .avatar-initials-sm {
    background: linear-gradient(135deg, #f97316, #ea580c);
    display: flex; align-items: center; justify-content: center;
    font-family: 'Rajdhani', sans-serif; font-size: 30px; font-weight: 700; color: white;
  }
  .avatar-overlay {
    position: absolute; inset: 0; border-radius: 50%;
    background: rgba(0,0,0,0.55); display: flex; align-items: center; justify-content: center;
    opacity: 0; transition: opacity 0.2s;
  }
  .avatar-upload:hover .avatar-overlay { opacity: 1; }
</style>
</head>
<body class="min-h-screen flex flex-col">

<div class="topbar">
  <div class="flex items-center gap-3">
    <span class="brand text-2xl font-bold text-orange-500">Headshield</span>
    <span class="text-gray-600 text-sm">/ Edit Profile</span>
  </div>
  <a href="/profile" class="text-gray-400 hover:text-white text-sm transition">← Back to Profile</a>
</div>

<div class="max-w-2xl mx-auto w-full px-4 py-10">

  <!-- Alerts -->
  <% if (typeof error !== 'undefined' && error) { %>
    <div class="bg-red-500/15 border border-red-500/40 text-red-300 px-4 py-3 rounded-lg text-sm mb-5">
      <%= error %>
    </div>
  <% } %>

  <div class="card p-8">
    <h2 class="text-xl font-semibold mb-7">Edit Profile</h2>

    <form method="POST" action="/profile/edit" enctype="multipart/form-data" id="editForm">

      <!-- Avatar -->
      <div class="flex items-center gap-5 mb-8 pb-6 border-b border-white/5">
        <label class="avatar-upload" for="avatarInput">
          <% if (user.profileImage) { %>
            <img src="<%= user.profileImage %>" alt="Profile" id="avatarPreview">
          <% } else { %>
            <div class="avatar-initials-sm" id="avatarInitials">
              <%= user.name ? user.name.charAt(0).toUpperCase() : 'U' %>
            </div>
          <% } %>
          <div class="avatar-overlay">
            <svg class="w-6 h-6 text-white" fill="none" stroke="currentColor" viewBox="0 0 24 24">
              <path stroke-width="2" d="M3 9a2 2 0 012-2h.93a2 2 0 001.664-.89l.812-1.22A2 2 0 0110.07 4h3.86a2 2 0 011.664.89l.812 1.22A2 2 0 0018.07 7H19a2 2 0 012 2v9a2 2 0 01-2 2H5a2 2 0 01-2-2V9z"/>
              <path stroke-width="2" d="M15 13a3 3 0 11-6 0 3 3 0 016 0z"/>
            </svg>
          </div>
        </label>
        <input type="file" id="avatarInput" name="profileImage" accept="image/*" class="hidden">
        <div>
          <p class="text-sm font-medium text-white">Profile Photo</p>
          <p class="text-xs text-gray-500 mt-1">Click the photo to change. JPG, PNG or WEBP. Max 2MB.</p>
          <button type="button" onclick="document.getElementById('avatarInput').click()"
            class="mt-2 text-xs text-orange-400 hover:underline">Upload New Photo</button>
        </div>
      </div>

      <!-- Name -->
      <div class="grid grid-cols-2 gap-4 mb-5">
        <div>
          <label class="input-label">First Name</label>
          <input type="text" name="firstName" class="input-field" 
            value="<%= user.name ? user.name.split(' ')[0] : '' %>" placeholder="First name">
          <p class="text-red-400 text-xs mt-1 hidden error-msg"></p>
        </div>
        <div>
          <label class="input-label">Last Name</label>
          <input type="text" name="lastName" class="input-field"
            value="<%= user.name && user.name.split(' ').length > 1 ? user.name.split(' ').slice(1).join(' ') : '' %>"
            placeholder="Last name">
          <p class="text-red-400 text-xs mt-1 hidden error-msg"></p>
        </div>
      </div>

      <!-- Phone -->
      <div class="mb-5">
        <label class="input-label">Phone Number</label>
        <input type="tel" name="phone" class="input-field"
          value="<%= user.phone || '' %>" placeholder="+91 98765 43210">
      </div>

      <!-- DOB + Gender -->
      <div class="grid grid-cols-2 gap-4 mb-5">
        <div>
          <label class="input-label">Date of Birth</label>
          <input type="date" name="dob" class="input-field"
            value="<%= user.dob ? new Date(user.dob).toISOString().split('T')[0] : '' %>">
        </div>
        <div>
          <label class="input-label">Gender</label>
          <select name="gender" class="input-field">
            <option value="">Select gender</option>
            <option value="Male" <%= user.gender === 'Male' ? 'selected' : '' %>>Male</option>
            <option value="Female" <%= user.gender === 'Female' ? 'selected' : '' %>>Female</option>
            <option value="Other" <%= user.gender === 'Other' ? 'selected' : '' %>>Other</option>
            <option value="Prefer not to say" <%= user.gender === 'Prefer not to say' ? 'selected' : '' %>>Prefer not to say</option>
          </select>
        </div>
      </div>

      <!-- Email (read-only, link to change) -->
      <div class="mb-7">
        <label class="input-label">Email Address</label>
        <div class="flex items-center gap-3">
          <input type="email" value="<%= user.email %>" class="input-field flex-1 opacity-50 cursor-not-allowed" disabled>
          <a href="/profile/edit-email" class="text-orange-400 text-xs hover:underline whitespace-nowrap">Change Email</a>
        </div>
        <p class="text-gray-600 text-xs mt-1">Email changes require OTP verification.</p>
      </div>

      <!-- Actions -->
      <div class="flex items-center gap-3 pt-2">
        <button type="submit" class="btn-primary">Save Changes</button>
        <a href="/profile" class="btn-cancel">Cancel</a>
      </div>
    </form>
  </div>
</div>

<script>
// Avatar preview
document.getElementById('avatarInput').addEventListener('change', function(e) {
  const file = e.target.files[0];
  if (!file) return;
  const reader = new FileReader();
  reader.onload = function(ev) {
    const container = document.querySelector('.avatar-upload');
    const existing = container.querySelector('img, .avatar-initials-sm');
    if (existing) existing.remove();
    const img = document.createElement('img');
    img.src = ev.target.result;
    img.id = 'avatarPreview';
    img.style.cssText = 'width:100px;height:100px;border-radius:50%;border:3px solid #f97316;object-fit:cover;';
    container.insertBefore(img, container.querySelector('.avatar-overlay'));
  };
  reader.readAsDataURL(file);
});

// Form validation
document.getElementById('editForm').addEventListener('submit', function(e) {
  let valid = true;
  const firstName = this.querySelector('[name="firstName"]');
  const lastName = this.querySelector('[name="lastName"]');
  const phone = this.querySelector('[name="phone"]');

  document.querySelectorAll('.error-msg').forEach(el => el.classList.add('hidden'));
  document.querySelectorAll('.input-field').forEach(el => el.classList.remove('border-red-500'));

  if (firstName.value.trim().length < 2) {
    showErr(firstName, 'First name must be at least 2 characters');
    valid = false;
  }
  if (phone.value && !/^\+?[\d\s\-]{10,14}$/.test(phone.value.trim())) {
    showErr(phone, 'Enter a valid phone number');
    valid = false;
  }

  if (!valid) e.preventDefault();
});

function showErr(input, msg) {
  input.classList.add('border-red-500');
  const err = input.parentElement.querySelector('.error-msg') || input.nextElementSibling;
  if (err) { err.textContent = msg; err.classList.remove('hidden'); }
}
</script>
</body>
</html>
