<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Edit Address</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-900 text-white min-h-screen flex items-center justify-center">

<div class="bg-gray-800 p-8 rounded-lg w-full max-w-lg">

  <h2 class="text-2xl font-bold mb-6 text-center">Edit Address</h2>

<form method="POST" action="/profile/addresses/<%= address._id %>/edit" novalidate>

    
<input 
  name="name" 
  value="<%= address.name %>"
  placeholder="Full Name"
  class="w-full p-3 mb-3 bg-gray-700 rounded"
  required
  pattern="^[A-Za-z][A-Za-z\s]{2,49}$"
  title="Name must be 3–50 characters, letters only, no symbols"
>

    
<input 
  name="phone" 
  value="<%= address.phone %>"
  placeholder="Phone"
  class="w-full p-3 mb-3 bg-gray-700 rounded"
  required
  pattern="^[6-9]\d{9}$"
  maxlength="10"
  title="Enter valid Indian number (starts with 6-9)"
>

<input 
  name="street" 
  value="<%= address.street %>"
  placeholder="Street"
  class="w-full p-3 mb-3 bg-gray-700 rounded"
  required
  minlength="5"
  maxlength="100"
>

  <input 
  name="city" 
  value="<%= address.city %>"
  placeholder="City"
  class="w-full p-3 mb-3 bg-gray-700 rounded"
  required
  pattern="^[A-Za-z ]+$"
  title="City should contain only letters"
/>

   <input 
  name="state" 
  value="<%= address.state %>"
  placeholder="State"
  class="w-full p-3 mb-3 bg-gray-700 rounded"
  required
  pattern="^[A-Za-z ]+$"
  title="State should contain only letters"
/>

  <input 
  name="pincode" 
  value="<%= address.pincode %>"
  placeholder="Pincode"
  class="w-full p-3 mb-3 bg-gray-700 rounded"
  required
  pattern="[0-9]{6}"
  maxlength="6"
  title="Enter a valid 6-digit pincode"
/>

    <!-- default -->
    <label class="text-sm flex items-center gap-2 mt-2">
      <input type="checkbox" name="isDefault"
        <%= address.isDefault ? "checked" : "" %>
      >
      Set as Default
    </label>

    <!-- button -->
    <div class="flex gap-4 mt-6">

      <button 
        type="submit"
        class="flex-1 bg-orange-500 py-3 rounded hover:bg-orange-600">
        Update Address
      </button>

      <button 
        type="button"
        onclick="window.location.href='/profile/addresses'"
        class="flex-1 bg-gray-600 py-3 rounded hover:bg-gray-500">
        Cancel
      </button>

    </div>
    <script>
document.querySelector("form").addEventListener("submit", function(e) {

  const name = document.querySelector("[name='name']").value.trim();
  const phone = document.querySelector("[name='phone']").value.trim();
  const city = document.querySelector("[name='city']").value.trim();
  const state = document.querySelector("[name='state']").value.trim();

  // Name check
  if (!/^[A-Za-z\s]{3,50}$/.test(name)) {
    alert("Invalid name (only letters, min 3 chars)");
    e.preventDefault();
    return;
  }

  // Phone check
  if (!/^[6-9]\d{9}$/.test(phone)) {
    alert("Invalid phone number");
    e.preventDefault();
    return;
  }

  // City / State
  if (!/^[A-Za-z\s]{3,50}$/.test(city) || !/^[A-Za-z\s]{3,50}$/.test(state)) {
    alert("City/State must be valid letters only");
    e.preventDefault();
    return;
  }

});
</script>

  </form>

</div>

</body>
</html>
