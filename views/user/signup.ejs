<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Headshield - Sign Up</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <style>
        body {
            font-family: 'Segoe UI', Tahoma, Geneva, Verdana, sans-serif;
        }
    </style>
</head>
<body class="relative min-h-screen">
    <!-- Background Image with Overlay -->
    <div class="fixed inset-0 bg-cover bg-center bg-no-repeat" style="background-image: url('/public/img/bgSignup.jpg');"></div>
    <div class="fixed inset-0 bg-black/50"></div>

    <div class="relative flex flex-col items-center justify-center min-h-screen px-4 py-12">
        <!-- Welcome Text -->
        <div class="text-center text-white mb-12">
            <h1 class="text-5xl md:text-6xl font-bold mb-4 tracking-wider drop-shadow-2xl">Welcome to Headshield</h1>
            <p class="text-lg md:text-xl opacity-90 drop-shadow-lg">Ride with confidence, shielded by the best. Your safety, our priority.</p>
        </div>

        <!-- Signup Form -->
        <div class="bg-black/70 backdrop-blur-md p-8 md:p-12 rounded-lg w-full max-w-md shadow-2xl">
            <h2 class="text-white text-3xl font-semibold text-center mb-8">Sign up</h2>

            <!-- Show error message if any (from controller) -->
            <% if (error) { %>
                <div class="bg-red-500/30 border border-red-500 text-white p-3 rounded mb-6 text-center">
                    <%= error %>
                </div>
            <% } %>

            <form method="POST" action="/signup" class="space-y-6">
                <!-- First & Last Name -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label for="firstName" class="block text-gray-300 text-sm font-medium mb-2">First name</label>
                        <input 
                            type="text" 
                            id="firstName" 
                            name="firstName" 
                            placeholder="Enter your first name" 
                            required 
                            class="w-full px-4 py-3 bg-gray-800/80 border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-gray-500"
                        >
                    </div>
                    <div>
                        <label for="lastName" class="block text-gray-300 text-sm font-medium mb-2">Last name</label>
                        <input 
                            type="text" 
                            id="lastName" 
                            name="lastName" 
                            placeholder="Enter your last name" 
                            required 
                            class="w-full px-4 py-3 bg-gray-800/80 border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-gray-500"
                        >
                    </div>
                </div>

                <!-- Email -->
                <div>
                    <label for="email" class="block text-gray-300 text-sm font-medium mb-2">Email address</label>
                    <input 
                        type="email" 
                        id="email" 
                        name="email" 
                        placeholder="Enter your email" 
                        required 
                        class="w-full px-4 py-3 bg-gray-800/80 border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-gray-500"
                    >
                </div>

                <!-- Password & Confirm Password -->
                <div class="grid grid-cols-1 md:grid-cols-2 gap-4">
                    <div>
                        <label for="password" class="block text-gray-300 text-sm font-medium mb-2">Password</label>
                        <input 
                            type="password" 
                            id="password" 
                            name="password" 
                            placeholder="Enter password" 
                            required 
                            class="w-full px-4 py-3 bg-gray-800/80 border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-gray-500"
                        >
                    </div>
                    <div>
                        <label for="confirmPassword" class="block text-gray-300 text-sm font-medium mb-2">Confirm password</label>
                        <input 
                            type="password" 
                            id="confirmPassword" 
                            name="confirmPassword" 
                            placeholder="Confirm password" 
                            required 
                            class="w-full px-4 py-3 bg-gray-800/80 border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-gray-500"
                        >
                    </div>
                </div>

                <!-- Submit Button -->
                <button type="submit" class="w-full py-4 bg-gradient-to-r from-orange-500 to-orange-400 text-white font-semibold rounded hover:from-orange-600 hover:to-orange-500 transition shadow-lg">
                    Sign Up
                </button>

                <!-- Divider -->
                <div class="flex items-center my-8">
                    <div class="flex-1 h-px bg-gray-600"></div>
                    <span class="px-4 text-gray-500 text-sm">or</span>
                    <div class="flex-1 h-px bg-gray-600"></div>
                </div>

                <!-- Google Login (placeholder) -->
                <button type="button" class="w-full py-4 bg-red-600 text-white font-semibold rounded hover:bg-red-700 transition shadow-lg">
                    Sign Up With Google
                </button>

                <!-- Login Link -->
                <p class="text-center text-gray-400 text-sm mt-6">
                    Have an account? 
                    <a href="/login" class="text-blue-400 font-semibold hover:underline">Login</a>
                </p>
            </form>
        </div>

        <!-- Logo Bottom Left -->
        <div class="absolute bottom-8 left-8 bg-black/60 backdrop-blur-sm p-6 rounded-lg shadow-lg">
            <img src="/public/icon/logo.png" alt="HEAD-SHIELD Logo" class="w-48 md:w-64 h-auto max-w-none">
        </div>
    </div>
</body>
</html>