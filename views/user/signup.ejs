<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Sign Up - Headshield</title>
    <script src="https://cdn.tailwindcss.com"></script>
    <link rel="stylesheet" href="https://cdnjs.cloudflare.com/ajax/libs/font-awesome/6.5.0/css/all.min.css">
</head>
<body class="relative min-h-screen">
    <!-- Background -->
    <div class="fixed inset-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1920&q=80');"></div>
    <div class="fixed inset-0 bg-black/60"></div>

    <!-- Content -->
    <div class="relative flex flex-col items-center justify-center min-h-screen px-4 py-12">
        <!-- Header -->
        <div class="text-center text-white mb-12">
            <h1 class="text-6xl font-bold mb-4 tracking-wider drop-shadow-2xl">Headshield</h1>
            <p class="text-xl opacity-90 drop-shadow-lg">Ride with confidence, shielded by the best. Your safety, our priority.</p>
        </div>

        <!-- Form Card -->
        <div class="bg-black/70 backdrop-blur-md p-10 rounded-lg w-full max-w-2xl shadow-2xl">
            <h2 class="text-white text-3xl font-semibold text-center mb-8">Sign Up</h2>

            <!-- Error Message -->
            <% if (error) { %>
                <div class="bg-red-500/30 border border-red-500 text-white p-3 rounded mb-6 text-center">
                    <%= error %>
                </div>
            <% } %>

            <!-- Success Message -->
            <% if (success) { %>
                <div class="bg-green-500/30 border border-green-500 text-white p-3 rounded mb-6 text-center">
                    <%= success %>
                </div>
            <% } %>

        <form method="POST" action="/signup" id="signupForm" novalidate>
                <!-- Name -->
                <div class="grid grid-cols-2 gap-4 mb-4">
                    <div>
                        <label class="block text-gray-300 text-sm mb-2">First Name *</label>
                        <input type="text" name="firstName" id="firstName" 
                               class="w-full px-4 py-3 bg-gray-800/80 border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-orange-500">
                    </div>
                    <div>
                        <label class="block text-gray-300 text-sm mb-2">Last Name *</label>
                        <input type="text" name="lastName" id="lastName" 
                               class="w-full px-4 py-3 bg-gray-800/80 border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-orange-500">
                    </div>
                </div>

                <!-- Email -->
                <div class="mb-4">
                    <label class="block text-gray-300 text-sm mb-2">Email Address *</label>
                    <input type="email" name="email" id="email" 
                           class="w-full px-4 py-3 bg-gray-800/80 border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-orange-500">
                </div>

                <!-- Password -->
<div class="grid grid-cols-2 gap-4 mb-6">
    
    <!-- Password -->
    <div class="relative">
        <label class="block text-gray-300 text-sm mb-2">Password *</label>

        <input type="password" name="password" id="password" minlength="6"
               class="w-full px-4 py-3 bg-gray-800/80 border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-orange-500">

        <!-- 👁 Eye Icon -->
      <span onclick="togglePassword('password', this)" 
      class="absolute right-3 top-11 cursor-pointer text-gray-400">
  <i class="fa-solid fa-eye"></i>
</span>

        <p class="text-gray-400 text-xs mt-1">Min 6 characters</p>
    </div>

    <!-- Confirm Password -->
    <div class="relative">
        <label class="block text-gray-300 text-sm mb-2">Confirm Password *</label>

        <input type="password" name="confirmPassword" id="confirmPassword" minlength="6"
               class="w-full px-4 py-3 bg-gray-800/80 border border-gray-700 rounded text-white placeholder-gray-500 focus:outline-none focus:border-orange-500">

      <span onclick="togglePassword('confirmPassword', this)" 
      class="absolute right-3 top-11 cursor-pointer text-gray-400">
  <i class="fa-solid fa-eye"></i>
</span>
    </div>

</div>

                <!-- Submit -->
                <button type="submit"
                        class="w-full py-4 bg-gradient-to-r from-orange-500 to-orange-600 text-white font-semibold rounded hover:from-orange-600 hover:to-orange-700 transition shadow-lg">
                    Sign Up
                </button>

                <!-- Divider -->
                <div class="flex items-center my-6">
                    <div class="flex-1 h-px bg-gray-600"></div>
                    <span class="px-4 text-gray-400 text-sm">or</span>
                    <div class="flex-1 h-px bg-gray-600"></div>
                </div>

                <!-- Google -->
                <a href="/auth/google"
                   class="w-full py-4 bg-red-600 text-white font-semibold rounded hover:bg-red-700 transition shadow-lg flex items-center justify-center gap-2">
                    <svg class="w-5 h-5" viewBox="0 0 24 24">
                        <path fill="currentColor" d="M22.56 12.25c0-.78-.07-1.53-.2-2.25H12v4.26h5.92c-.26 1.37-1.04 2.53-2.21 3.31v2.77h3.57c2.08-1.92 3.28-4.74 3.28-8.09z"/>
                        <path fill="currentColor" d="M12 23c2.97 0 5.46-.98 7.28-2.66l-3.57-2.77c-.98.66-2.23 1.06-3.71 1.06-2.86 0-5.29-1.93-6.16-4.53H2.18v2.84C3.99 20.53 7.7 23 12 23z"/>
                        <path fill="currentColor" d="M5.84 14.09c-.22-.66-.35-1.36-.35-2.09s.13-1.43.35-2.09V7.07H2.18C1.43 8.55 1 10.22 1 12s.43 3.45 1.18 4.93l2.85-2.22.81-.62z"/>
                        <path fill="currentColor" d="M12 5.38c1.62 0 3.06.56 4.21 1.64l3.15-3.15C17.45 2.09 14.97 1 12 1 7.7 1 3.99 3.47 2.18 7.07l3.66 2.84c.87-2.6 3.3-4.53 6.16-4.53z"/>
                    </svg>
                    Sign Up With Google
                </a>

                <!-- Login Link -->
                <p class="text-center text-gray-400 text-sm mt-6">
                    Have an account? 
                    <a href="/login" class="text-orange-400 font-semibold hover:underline">Login</a>
                </p>
            </form>
        </div>

        <!-- Logo -->
        <div class="absolute bottom-8 left-8 bg-black/60 backdrop-blur-sm p-6 rounded-lg">
            <img src="/icon/symbol.jpg" alt="Headshield" class="w-32">
        </div>
    </div>
<script>
const form = document.getElementById("signupForm");

form.addEventListener("submit", function (e) {
    let isValid = true;

    clearErrors();

    const firstName = document.getElementById("firstName");
    const lastName = document.getElementById("lastName");
    const email = document.getElementById("email");
    const password = document.getElementById("password");
    const confirmPassword = document.getElementById("confirmPassword");

    // First Name
    if (firstName.value.trim().length < 2) {
        showError(firstName, "First name must be at least 2 characters");
        isValid = false;
    }

    // Last Name
    if (lastName.value.trim().length < 2) {
        showError(lastName, "Last name must be at least 2 characters");
        isValid = false;
    }

    // Email
    const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;
    if (!emailRegex.test(email.value)) {
        showError(email, "Enter a valid email address");
        isValid = false;
    }

    // Password (Strong)
    const passwordRegex = /^(?=.*[A-Z])(?=.*[a-z])(?=.*\d).{6,}$/;
    if (!passwordRegex.test(password.value)) {
        showError(password, "Password must include uppercase, lowercase, number");
        isValid = false;
    }

    // Confirm Password
    if (password.value !== confirmPassword.value) {
        showError(confirmPassword, "Passwords do not match");
        isValid = false;
    }

    if (!isValid) e.preventDefault();
});


// 🔹 Show error below input
function showError(input, message) {
    const error = document.createElement("p");
    error.className = "text-red-400 text-xs mt-1";
    error.innerText = message;

    input.classList.add("border-red-500");

    input.parentElement.appendChild(error);
}


// 🔹 Clear old errors
function clearErrors() {
    document.querySelectorAll(".text-red-400").forEach(el => el.remove());
    document.querySelectorAll("input").forEach(input => {
        input.classList.remove("border-red-500");
    });
}
</script>
<script>
function togglePassword(inputId, icon) {
    const input = document.getElementById(inputId);

    if (input.type === "password") {
        input.type = "text";
    } else {
        input.type = "password";
    }
}
</script>
</body>
</html>