<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Change Password</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="min-h-screen flex items-center justify-center bg-gray-900 text-white">

<div class="bg-black/70 p-10 rounded-lg w-full max-w-md">

    <h2 class="text-2xl font-semibold text-center mb-6">Change Password</h2>

    <% if (typeof error !== 'undefined' && error) { %>
        <p class="text-red-400 text-sm text-center mb-4"><%= error %></p>
    <% } %>

    <% if (typeof message !== 'undefined' && message) { %>
        <p class="text-green-400 text-sm text-center mb-4"><%= message %></p>
    <% } %>

    <form method="POST" action="/profile/change-password">

        <div class="mb-4">
            <label>Current Password</label>
            <input type="password" name="currentPassword" required
                   class="w-full px-4 py-2 bg-gray-800 border rounded mt-1">
        </div>

        <div class="mb-4">
            <label>New Password</label>
            <input type="password" name="newPassword" required
                   class="w-full px-4 py-2 bg-gray-800 border rounded mt-1">
        </div>

        <div class="mb-4">
            <label>Confirm Password</label>
            <input type="password" name="confirmPassword" required
                   class="w-full px-4 py-2 bg-gray-800 border rounded mt-1">
        </div>

        <button class="w-full bg-orange-500 py-3 rounded mt-4">
            Update Password
        </button>

    </form>

</div>

</body>
</html>