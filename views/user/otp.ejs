<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="UTF-8">
    <meta name="viewport" content="width=device-width, initial-scale=1.0">
    <title>Verify OTP - Headshield</title>
    <script src="https://cdn.tailwindcss.com"></script>
</head>
<body class="relative min-h-screen">
    <!-- Background -->
    <div class="fixed inset-0 bg-cover bg-center" style="background-image: url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1920&q=80');"></div>
    <div class="fixed inset-0 bg-black/65"></div>

    <!-- Content -->
    <div class="relative flex flex-col items-center justify-center min-h-screen px-4 py-12">
        <!-- Header -->
        <div class="text-center text-white mb-12">
            <h1 class="text-6xl font-bold mb-4 tracking-wider">Headshield</h1>
            <p class="text-xl opacity-90">Ride with confidence, shielded by the best. Your safety, our priority.</p>
        </div>

        <!-- OTP Card -->
        <div class="bg-black/70 backdrop-blur-md p-10 rounded-lg w-full max-w-md shadow-2xl">
            <h2 class="text-white text-2xl font-semibold text-center mb-3">Enter the OTP</h2>
            
            <p class="text-gray-300 text-sm text-center mb-8">
                The OTP was sent to your email<br>
                <span class="text-orange-400"><%= email %></span>
            </p>

            <!-- Error -->
            <% if (error) { %>
                <div class="bg-red-500/30 border border-red-500 text-white p-3 rounded mb-6 text-center text-sm">
                    <%= error %>
                </div>
            <% } %>

            <!-- Success -->
            <% if (success) { %>
                <div class="bg-green-500/30 border border-green-500 text-white p-3 rounded mb-6 text-center text-sm">
                    <%= success %>
                </div>
            <% } %>

            <form method="POST" action="/verify-otp" id="otpForm">
                <input type="hidden" name="email" value="<%= email %>">
                
                <div class="mb-6">
                    <label class="block text-white text-sm mb-3">Enter OTP</label>
                    <input 
                        type="text" 
                        name="otp" 
                        id="otp"
                        placeholder="Enter 6-digit OTP" 
                        maxlength="6"
                        required
                        class="w-full px-4 py-3 bg-gray-800/80 border border-gray-700 rounded text-white text-center text-2xl tracking-widest placeholder-gray-500 focus:outline-none focus:border-orange-500"
                    >
                </div>

                <button type="submit"
                        class="w-full py-3 bg-gradient-to-r from-orange-500 to-orange-600 text-white font-semibold rounded hover:from-orange-600 hover:to-orange-700 transition mb-4">
                    Verify OTP
                </button>
            </form>

            <!-- Resend -->
            <div class="mt-6 text-center">
                <p class="text-gray-400 text-sm mb-2" id="timer-text">
                    Resend OTP in <span id="countdown" class="text-orange-400 font-semibold">60</span>s
                </p>
                <button 
                    onclick="resendOTP()" 
                    class="text-orange-500 hover:text-orange-400 font-medium text-sm disabled:opacity-50 disabled:cursor-not-allowed"
                    id="resend-btn"
                    disabled
                >
                    Resend OTP
                </button>
            </div>

            <div class="text-center mt-4">
                <a href="/" class="text-gray-400 text-sm hover:text-white">← Back to Home</a>
            </div>
        </div>

        <!-- Logo -->
        <div class="absolute bottom-8 left-8 bg-black/60 backdrop-blur-sm p-6 rounded-lg">
            <img src="/headshield-logo.jpg" alt="Headshield" class="w-32">
        </div>
    </div>

    <script>
        // Timer
        let seconds = 60;
        const countdownEl = document.getElementById('countdown');
        const resendBtn = document.getElementById('resend-btn');
        const timerText = document.getElementById('timer-text');

        const timer = setInterval(() => {
            seconds--;
            countdownEl.textContent = seconds;
            
            if (seconds <= 0) {
                clearInterval(timer);
                timerText.style.display = 'none';
                resendBtn.disabled = false;
            }
        }, 1000);

        // Resend OTP
        async function resendOTP() {
            try {
                const response = await fetch('/resend-otp', {
                    method: 'POST',
                    headers: { 'Content-Type': 'application/json' },
                    body: JSON.stringify({ email: '<%= email %>' })
                });

                const data = await response.json();

                if (data.success) {
                    alert('New OTP sent to your email!');
                    location.reload();
                } else {
                    alert(data.message || 'Failed to send OTP');
                }
            } catch (error) {
                alert('Error sending OTP');
            }
        }

        // Form validation
        document.getElementById('otpForm').addEventListener('submit', function(e) {
            const otp = document.getElementById('otp').value.trim();

            if (!otp) {
                e.preventDefault();
                alert('Please enter OTP');
                return;
            }

            if (!/^\d+$/.test(otp)) {
                e.preventDefault();
                alert('OTP must contain only numbers');
                return;
            }

            if (otp.length !== 6) {
                e.preventDefault();
                alert('OTP must be exactly 6 digits');
                return;
            }
        });

        // Auto-focus and number-only input
        const otpInput = document.getElementById('otp');
        otpInput.addEventListener('input', function(e) {
            this.value = this.value.replace(/[^0-9]/g, '');
        });
    </script>
</body>
</html>