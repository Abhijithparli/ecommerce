<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Headshield</title>
<script src="https://cdn.tailwindcss.com"></script>

    
<style>
.bg-image {
    background-image: url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1920&q=80');
    background-size: cover;
    background-position: center;
}

/* Cinematic grayscale */
.bg-image::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.6);
    backdrop-filter: grayscale(100%);
}

/* Glass card enhancement */
.glass {
    background: rgba(0,0,0,0.6);
    backdrop-filter: blur(14px);
    border: 1px solid rgba(255,255,255,0.1);
}
</style>

</head>

<body class="bg-image min-h-screen flex items-center justify-center relative text-white">

<!-- Content -->
<div class="relative z-10 w-full max-w-6xl px-4">

    <!-- Header -->
    <div class="text-center mb-14">
        <h1 class="text-6xl font-bold tracking-wide">Headshield</h1>
        <p class="mt-3 text-lg text-gray-300">
            Ride with confidence, shielded by the best. Your safety, our priority.
        </p>
    </div>

    <!-- Card -->
    <div class="max-w-md mx-auto">
        <div class="glass rounded-xl p-10 shadow-2xl">

            <!-- Icon -->
            <div class="w-16 h-16 mx-auto mb-6 flex items-center justify-center rounded-full bg-white/10">
                <svg class="w-8 h-8" fill="none" stroke="white" viewBox="0 0 24 24">
                    <path stroke-width="2" d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
                </svg>
            </div>

            <!-- Title -->
            <h2 class="text-2xl text-center font-semibold mb-6">Forgot Password</h2>

            <!-- Form -->
            <form>
                <label class="block text-sm mb-2">Email Address</label>

                <input type="email"
                    placeholder="Enter your email address"
                    class="w-full px-4 py-3 mb-5 rounded-md bg-gray-900/60 border border-gray-600 focus:ring-2 focus:ring-orange-500 outline-none"
                >

                <button class="w-full py-3 rounded-md font-semibold bg-gradient-to-r from-orange-500 to-orange-600 hover:scale-[1.02] active:scale-[0.98] transition">
                    Next
                </button>
            </form>

        </div>
    </div>

</div>

</body>
</html>