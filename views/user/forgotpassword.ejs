<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Forgot Password - Headshield</title>
<script src="https://cdn.tailwindcss.com"></script>
<style>
  @import url('https://fonts.googleapis.com/css2?family=Rajdhani:wght@500;600;700&family=DM+Sans:wght@300;400;500&display=swap');
  * { font-family: 'DM Sans', sans-serif; }
  h1, h2 { font-family: 'Rajdhani', sans-serif; }
  .glass {
    background: rgba(0,0,0,0.62);
    backdrop-filter: blur(18px);
    border: 1px solid rgba(255,255,255,0.08);
  }
  .bg-scene {
    background-image: url('https://images.unsplash.com/photo-1558618666-fcd25c85cd64?w=1920&q=80');
    background-size: cover;
    background-position: center;
  }
  .bg-scene::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.65);
  }
  input:focus { box-shadow: 0 0 0 2px rgba(249,115,22,0.5); }
  .btn-primary {
    background: linear-gradient(135deg, #f97316, #ea580c);
    transition: all 0.2s;
  }
  .btn-primary:hover { transform: translateY(-1px); box-shadow: 0 8px 20px rgba(249,115,22,0.35); }
  .btn-primary:active { transform: translateY(0); }
</style>
</head>
<body class="bg-scene min-h-screen flex items-center justify-center relative text-white">

<!-- Logo -->
<div class="absolute bottom-6 left-6 z-10 bg-black/50 backdrop-blur-sm p-4 rounded-lg">
  <img src="/headshield-logo.jpg" alt="Headshield" class="w-28">
</div>

<!-- Content -->
<div class="relative z-10 w-full max-w-6xl px-4 py-12">

  <!-- Header -->
  <div class="text-center mb-14">
    <h1 class="text-6xl font-bold tracking-wider drop-shadow-2xl">Headshield</h1>
    <p class="mt-3 text-lg text-gray-300 drop-shadow">
      Ride with confidence, shielded by the best. Your safety, our priority.
    </p>
  </div>

  <!-- Card -->
  <div class="max-w-md mx-auto">
    <div class="glass rounded-xl p-10 shadow-2xl">

      <!-- Lock Icon -->
      <div class="w-16 h-16 mx-auto mb-6 flex items-center justify-center rounded-full border border-orange-500/40 bg-orange-500/10">
        <svg class="w-8 h-8 text-orange-400" fill="none" stroke="currentColor" viewBox="0 0 24 24">
          <path stroke-linecap="round" stroke-linejoin="round" stroke-width="2"
            d="M12 15v2m-6 4h12a2 2 0 002-2v-6a2 2 0 00-2-2H6a2 2 0 00-2 2v6a2 2 0 002 2zm10-10V7a4 4 0 00-8 0v4h8z"/>
        </svg>
      </div>

      <h2 class="text-2xl text-center font-semibold mb-2">Forgot Password?</h2>
      <p class="text-gray-400 text-sm text-center mb-8">
        Enter your registered email and we'll send you an OTP to reset your password.
      </p>

      <!-- Alerts -->
      <% if (typeof error !== 'undefined' && error) { %>
        <div class="bg-red-500/20 border border-red-500/50 text-red-300 p-3 rounded-lg mb-5 text-sm text-center">
          <%= error %>
        </div>
      <% } %>
      <% if (typeof success !== 'undefined' && success) { %>
        <div class="bg-green-500/20 border border-green-500/50 text-green-300 p-3 rounded-lg mb-5 text-sm text-center">
          <%= success %>
        </div>
      <% } %>

      <!-- Form -->
      <form method="POST" action="/forgot-password" id="forgotForm">
        <label class="block text-sm text-gray-300 mb-2">Email Address</label>
        <input 
          type="email" 
          name="email" 
          id="email"
          placeholder="yourname@email.com"
          
          class="w-full px-4 py-3 mb-1 rounded-lg bg-gray-900/70 border border-gray-600 text-white placeholder-gray-500 outline-none transition"
        >
        <p id="emailError" class="text-red-400 text-xs mb-4 hidden">Please enter a valid email address.</p>

        <button type="submit" class="btn-primary w-full py-3 mt-3 rounded-lg font-semibold text-white">
          Send OTP
        </button>
      </form>

      <!-- Divider -->
      <div class="flex items-center my-6">
        <div class="flex-1 h-px bg-gray-700"></div>
        <span class="px-3 text-gray-500 text-xs">or</span>
        <div class="flex-1 h-px bg-gray-700"></div>
      </div>

      <div class="flex justify-center gap-6 text-sm">
        <a href="/login" class="text-orange-400 hover:text-orange-300 transition font-medium">← Back to Login</a>
        <a href="/signup" class="text-gray-400 hover:text-white transition">Create Account</a>
      </div>

    </div>
  </div>
</div>

<script>
document.getElementById('forgotForm').addEventListener('submit', function(e) {
  const email = document.getElementById('email');
  const errEl = document.getElementById('emailError');
  const emailRegex = /^[^\s@]+@[^\s@]+\.[^\s@]{2,}$/;

  if (!emailRegex.test(email.value.trim())) {
    e.preventDefault();
    email.classList.add('border-red-500');
    errEl.classList.remove('hidden');
  } else {
    email.classList.remove('border-red-500');
    errEl.classList.add('hidden');
  }
});
</script>
</body>
</html>
