<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>My Addresses</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-900 text-white min-h-screen p-10">

<div class="max-w-4xl mx-auto">

  <!-- HEADER -->
  <div class="flex justify-between items-center mb-6">
    <h1 class="text-2xl font-bold">My Addresses</h1>

    <button onclick="toggleForm()"
      class="bg-orange-500 px-4 py-2 rounded hover:bg-orange-600">
      + Add Address
    </button>
    
  </div>

  <!-- SUCCESS / ERROR -->
  <% if (success) { %>
    <p class="text-green-400 mb-4"><%= success %></p>
  <% } %>

  <% if (error) { %>
    <p class="text-red-400 mb-4"><%= error %></p>
  <% } %>

  <!-- ADD FORM (HIDDEN) -->
<div id="addressForm" class="<%= error ? '' : 'hidden' %>">

<form method="POST" action="/profile/addresses/add" novalidate>

  <!-- NAME -->
 <div class="mb-3">
  <label class="text-sm">Full Name</label>
  <input name="name"
    required
    pattern="^[A-Za-z\s]{3,50}$"
    title="Name must be 3–50 letters only"
    class="w-full p-2 bg-gray-700 rounded">
  
  <p class="text-red-400 text-sm hidden"></p>
</div>
   

  <!-- PHONE -->
 <div class="mb-3">
  <label class="text-sm">Phone</label>
  <input name="phone"
    required
    pattern="^[6-9]\d{9}$"
    class="w-full p-2 bg-gray-700 rounded">

  <p class="text-red-400 text-sm hidden"></p>
</div>

  <!-- STREET -->
  <label class="text-sm">Street</label>
  <input name="street"
    required
    minlength="5"
    maxlength="100"
    title="Minimum 5 characters"
    class="w-full p-2 mb-2 bg-gray-700 rounded">
    <p class="text-red-400 text-sm hidden"></p>

  <!-- CITY -->
  <label class="text-sm">City</label>
  <input name="city"
    required
    pattern="^[A-Za-z\s]{3,50}$"
    title="City must contain only letters"
    class="w-full p-2 mb-2 bg-gray-700 rounded">
    <p class="text-red-400 text-sm hidden"></p>

  <!-- STATE -->
  <label class="text-sm">State</label>
  <input name="state"
    required
    pattern="^[A-Za-z\s]{3,50}$"
    title="State must contain only letters"
    class="w-full p-2 mb-2 bg-gray-700 rounded">
    <p class="text-red-400 text-sm hidden"></p>


  <!-- PINCODE -->
  <label class="text-sm">Pincode</label>
  <input name="pincode"
    required
    pattern="^[1-9][0-9]{5}$"
    maxlength="6"
    title="Enter valid 6-digit pincode"
    class="w-full p-2 mb-2 bg-gray-700 rounded">
    <p class="text-red-400 text-sm hidden"></p>

  <!-- DEFAULT -->
  <label class="text-sm">
    <input type="checkbox" name="isDefault"> Set as default
  </label>

  <!-- BUTTON -->
  <button class="bg-orange-500 px-4 py-2 rounded mt-3 w-full">
    Save Address
  </button>

</form>
  </div>
  <!-- ADDRESS LIST -->
  <div class="space-y-4">
<% if (addresses && addresses.length > 0) { %>

      <% addresses.forEach(addr => { %>

        <div class="bg-gray-800 p-4 rounded">

          <p class="font-bold"><%= addr.name %>
            <% if (addr.isDefault) { %>
              <span class="text-green-400 text-sm">(Default)</span>
            <% } %>
          </p>

          <p><%= addr.street %>, <%= addr.city %></p>
          <p><%= addr.state %> - <%= addr.pincode %></p>
          <p><%= addr.phone %></p>

      <div class="mt-3 flex gap-4 text-sm">

  <!-- edit -->
  <a href="/profile/addresses/<%= addr._id %>/edit"
     class="text-yellow-400 hover:text-yellow-300">
     Edit
  </a>

   <!-- delete -->
  <form action="/profile/addresses/<%= addr._id %>/delete"
        method="POST" class="inline">
    <button class="text-red-400">Delete</button>
  </form>
      </div>

  <!--   set default  -->
  <% if (!addr.isDefault) { %>
    <form action="/profile/addresses/<%= addr._id %>/default"
          method="POST" class="inline">
      <button class="text-blue-400">Set Default</button>
    </form>
        </div>
  <% } %>

</div>

        </div>

      <% }) %>

    <% } else { %>

      <p class="text-gray-400">No addresses added yet.</p>

    <% } %>

  </div>

<button type="button"
  onclick="window.location.href='/profile'"
  class="flex-1 bg-gray-700 py-3 rounded hover:bg-gray-600">
  Cancel
</button>

</div>

<script>
 
const form = document.querySelector("#addressForm form");

if (form) {
  form.addEventListener("submit", function(e) {

    let valid = true;

    const inputs = {
      name: form.querySelector("[name='name']"),
      phone: form.querySelector("[name='phone']"),
      street: form.querySelector("[name='street']"),
      city: form.querySelector("[name='city']"),
      state: form.querySelector("[name='state']"),
      pincode: form.querySelector("[name='pincode']")
    };

    // EMPTY CHECK
    for (let key in inputs) {
      if (!inputs[key].value.trim()) {
        showError(inputs[key], "This field is required");
        valid = false;
      } else {
        clearError(inputs[key]);
      }
    }

    // PATTERN VALIDATION
    if (!/^[A-Za-z\s]{3,50}$/.test(inputs.name.value.trim())) {
      console.log("waht is thei s")
      showError(inputs.name, "Invalid name");
      valid = false;
    }

    if (!/^[6-9]\d{9}$/.test(inputs.phone.value.trim())) {
      showError(inputs.phone, "Invalid phone");
      valid = false;
    }

    if (inputs.street.value.trim().length < 5) {
      showError(inputs.street, "Street too short");
      valid = false;
    }

    if (!/^[A-Za-z\s]{3,50}$/.test(inputs.city.value.trim())) {
      showError(inputs.city, "Invalid city");
      valid = false;
    }

    if (!/^[A-Za-z\s]{3,50}$/.test(inputs.state.value.trim())) {
      showError(inputs.state, "Invalid state");
      valid = false;
    }

    if (!/^[1-9][0-9]{5}$/.test(inputs.pincode.value.trim())) {
      showError(inputs.pincode, "Invalid pincode");
      valid = false;
    }

    if (!valid) {
      e.preventDefault();   
    }
  });
}

// ERROR UI
function showError(input, message) {
  input.classList.add("border-red-500");

  const container = input.closest(".mb-3");
  if(!container) return; //now
  const err = container.querySelector("p");

  err.textContent = message;
  err.classList.remove("hidden");
}

function clearError(input) {
  input.classList.remove("border-red-500");

  const container = input.closest(".mb-3");
  const err = container.querySelector("p");

  err.classList.add("hidden");
}
</script>
<script>
function toggleForm() {
  const formDiv = document.getElementById("addressForm");
  if (formDiv) formDiv.classList.toggle("hidden");
}
</script>

</body>
</html>