<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<title>Set Password</title>
<script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="min-h-screen flex items-center justify-center bg-gradient-to-br from-gray-900 to-gray-800 text-white">

<!-- CARD -->
<div class="bg-gray-900/90 backdrop-blur-lg p-8 rounded-2xl shadow-2xl w-full max-w-md border border-gray-700">

    <!-- TITLE -->
    <h2 class="text-3xl font-bold text-center mb-3 text-white">
        Set Your Password
    </h2>

    <p class="text-gray-400 text-sm text-center mb-6">
        You logged in via Google. Please set a password to secure your account.
    </p>

    <% if (typeof error !== 'undefined' && error) { %>
        <p class="text-red-400 text-sm text-center mb-4">
            <%= error %>
        </p>
    <% } %>

    <!-- FORM -->
    <form method="POST" action="/set-password" class="space-y-5">

        <!-- PASSWORD -->
        <div class="relative">
            <label class="block text-sm mb-1">New Password</label>

            <input
                type="password"
                id="password"
                name="password"
                placeholder="Enter new password"
                class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500"
            >

            <span onclick="togglePassword('password')"
                class="absolute right-3 top-10 cursor-pointer text-gray-400 hover:text-white">
                👁
            </span>
        </div>

        <!-- CONFIRM PASSWORD -->
        <div class="relative">
            <label class="block text-sm mb-1">Confirm Password</label>

            <input
                type="password"
                id="confirmPassword"
                name="confirmPassword"
                placeholder="Confirm password"
                class="w-full px-4 py-3 bg-gray-800 border border-gray-700 rounded-lg focus:outline-none focus:ring-2 focus:ring-orange-500"
            >

            <span onclick="togglePassword('confirmPassword')"
                class="absolute right-3 top-10 cursor-pointer text-gray-400 hover:text-white">
                👁
            </span>
        </div>

        <!-- BUTTON -->
        <button
            class="w-full bg-orange-500 hover:bg-orange-600 transition-all duration-300 py-3 rounded-lg font-semibold text-lg shadow-md">
            Set Password
        </button>

    </form>

</div>

<script>
document.querySelector("form").addEventListener("submit", function(e) {
  const newPass = document.querySelector("[name='password']").value.trim();
  const confirm = document.querySelector("[name='confirmPassword']").value.trim();

  if (!newPass || !confirm) {
    alert("All fields are required");
    e.preventDefault();
    return;
  }

  if (newPass.length < 6) {
    alert("Password must be at least 6 characters");
    e.preventDefault();
    return;
  }

  if (newPass !== confirm) {
    alert("Passwords do not match");
    e.preventDefault();
    return;
  }
});

function togglePassword(id) {
  const input = document.getElementById(id);
  input.type = input.type === "password" ? "text" : "password";
}
</script>

</body>
</html>