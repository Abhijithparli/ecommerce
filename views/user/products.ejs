<!DOCTYPE html>
<html lang="en">
<head>
  <meta charset="UTF-8">
  <title>Products</title>
  <script src="https://cdn.tailwindcss.com"></script>
</head>

<body class="bg-gray-100 min-h-screen">

<div class="max-w-7xl mx-auto px-6 py-10">

  <!-- HEADER -->
  <div class="flex justify-between items-center mb-8">

    <h1 class="text-3xl font-bold text-gray-800">
      Products
    </h1>

  </div>


  <!-- SEARCH + FILTER -->
  <div class="bg-white rounded-xl shadow p-6 mb-8">

    <form
      method="GET"
      action="/products"
      class="grid grid-cols-1 md:grid-cols-4 gap-4"
    >

      <!-- SEARCH -->
      <input
        type="text"
        name="search"
        value="<%= search %>"
        placeholder="Search products..."
        class="border rounded-lg px-4 py-3"
      >

      <!-- CATEGORY -->
      <select
        name="category"
        class="border rounded-lg px-4 py-3"
      >

        <option value="">
          All Categories
        </option>

        <% categories.forEach(cat => { %>

          <option
            value="<%= cat._id %>"

            <%= category == cat._id.toString()
              ? "selected"
              : ""
            %>
          >
            <%= cat.name %>
          </option>

        <% }) %>

      </select>


      <!-- SORT -->
      <select
        name="sort"
        class="border rounded-lg px-4 py-3"
      >

        <option value="">
          Sort By
        </option>

        <option
          value="low-high"
          <%= sort === "low-high" ? "selected" : "" %>
        >
          Price Low to High
        </option>

        <option
          value="high-low"
          <%= sort === "high-low" ? "selected" : "" %>
        >
          Price High to Low
        </option>

        <option
          value="a-z"
          <%= sort === "a-z" ? "selected" : "" %>
        >
          A-Z
        </option>

        <option
          value="z-a"
          <%= sort === "z-a" ? "selected" : "" %>
        >
          Z-A
        </option>

      </select>


      <!-- BUTTONS -->
      <div class="flex gap-3">

        <button
          class="bg-orange-500 hover:bg-orange-600 text-white px-6 py-3 rounded-lg"
        >
          Apply
        </button>

        <a
          href="/products"
          class="bg-gray-300 hover:bg-gray-400 px-6 py-3 rounded-lg"
        >
          Clear
        </a>

      </div>

    </form>

  </div>


  <!-- PRODUCT GRID -->
  <div class="grid grid-cols-1 sm:grid-cols-2 lg:grid-cols-4 gap-8">

    <% if (products.length > 0) { %>

      <% products.forEach(product => { %>

        <div class="bg-white rounded-2xl shadow hover:shadow-lg transition overflow-hidden">

          <!-- IMAGE -->
          <img
            src="<%= product.images[0] %>"
            class="w-full h-64 object-cover"
          >

          <!-- CONTENT -->
          <div class="p-5">

            <!-- NAME -->
            <h2 class="text-lg font-semibold text-gray-800 mb-2">

              <%= product.name %>

            </h2>

            <!-- BRAND -->
            <p class="text-sm text-gray-500 mb-2">

              <%= product.brand %>

            </p>

            <!-- PRICE -->
            <div class="flex items-center gap-3 mb-4">

              <span class="text-xl font-bold text-orange-600">

                ₹<%= product.salePrice %>

              </span>

              <span class="text-sm line-through text-gray-400">

                ₹<%= product.regularPrice %>

              </span>

            </div>

            <!-- BUTTON -->
            <a
              href="/products/<%= product._id %>"
              class="block text-center bg-gray-900 hover:bg-black text-white py-3 rounded-lg"
            >
              View Product
            </a>

          </div>

        </div>

      <% }) %>

    <% } else { %>

      <div class="col-span-full text-center py-20">

        <h2 class="text-2xl font-semibold text-gray-500">
          No Products Found
        </h2>

      </div>

    <% } %>

  </div>


  <!-- PAGINATION -->
  <% if (totalPages > 1) { %>

    <div class="flex justify-center mt-12 gap-3">

      <% for (let i = 1; i <= totalPages; i++) { %>

        <a
          href="/products?page=<%= i %>&search=<%= search %>&category=<%= category %>&sort=<%= sort %>"
          class="
            px-4 py-2 rounded-lg

            <%= currentPage === i
              ? 'bg-orange-500 text-white'
              : 'bg-white text-gray-800'
            %>
          "
        >

          <%= i %>

        </a>

      <% } %>

    </div>

  <% } %>

</div>

</body>
</html>