<!DOCTYPE html>
<html lang="en">
<head>
<meta charset="UTF-8">
<meta name="viewport" content="width=device-width, initial-scale=1.0">
<title>Headshield OTP</title>

<script src="https://cdn.tailwindcss.com"></script>

<style>
.bg-image {
    background-image: url('bg.jpg');
    background-size: cover;
    background-position: center;
}

/* Cinematic overlay */
.bg-image::before {
    content: "";
    position: absolute;
    inset: 0;
    background: rgba(0,0,0,0.7);
    backdrop-filter: grayscale(100%);
}

/* Better glass effect */
.glass {
    background: rgba(0,0,0,0.65);
    backdrop-filter: blur(16px);
    border: 1px solid rgba(255,255,255,0.08);
}
</style>

</head>

<body class="bg-image min-h-screen flex items-center justify-center relative text-white">

<!-- Logo -->
<div class="absolute bottom-6 left-6 z-10">
    <img src="logo.png" class="w-28">
</div>

<!-- Content -->
<div class="relative z-10 w-full max-w-6xl px-4">

    <!-- Header -->
    <div class="text-center mb-12">
        <h1 class="text-6xl font-bold tracking-wide">Headshield</h1>
        <p class="text-gray-300 mt-2">
            Ride with confidence, shielded by the best. Your safety, our priority.
        </p>
    </div>

    <!-- Card -->
    <div class="max-w-md mx-auto">
        <div class="glass rounded-xl p-10 shadow-2xl">

            <h2 class="text-2xl text-center font-semibold mb-3">Enter the OTP</h2>

            <p class="text-gray-400 text-sm text-center mb-6">
                The OTP was sent to your registered email<br>
                Please check the spam folder
            </p>

            <form method="POST" action="/verify-otp">
                <input type="hidden" name="userId" value="<%= userId %>">

                <label class="block text-sm mb-2">Enter OTP</label>

                <input 
                    type="text" 
                    name="otp"
                    maxlength="6"
                    placeholder="Enter OTP"
                    class="w-full px-4 py-3 mb-5 rounded-md bg-gray-900/60 border border-gray-600 focus:ring-2 focus:ring-orange-500 outline-none text-center tracking-[10px]"
                >

                 <button 
        type="submit"
        class="w-full py-3 rounded-md font-semibold bg-gradient-to-r from-orange-500 to-orange-600 hover:scale-[1.02] active:scale-[0.98] transition"
    >
        Submit
    </button>
            </form>

            <!-- Back -->
            <div class="text-center">
                <a href="/" class="text-gray-400 text-sm hover:text-white">
                    Back to Home
                </a>
            </div>

            <!-- Resend -->
            <div class="mt-6 text-center">
                <p class="text-gray-400 text-sm">
                    Didn't receive the code?
                    <button onclick="resendOTP()" id="resend-btn"
                        class="text-orange-500 hover:text-orange-400 ml-1">
                        Resend OTP
                    </button>
                </p>
                <p class="text-gray-500 text-xs mt-2" id="timer"></p>
            </div>

        </div>
    </div>

</div>

<script>
let timerSeconds = 60;
let timerInterval;

function startTimer() {
    const timer = document.getElementById('timer');
    const btn = document.getElementById('resend-btn');

    btn.disabled = true;
    btn.classList.add('opacity-50');

    timerInterval = setInterval(() => {
        timerSeconds--;
        timer.textContent = `Resend in ${timerSeconds}s`;

        if (timerSeconds <= 0) {
            clearInterval(timerInterval);
            timer.textContent = '';
            btn.disabled = false;
            btn.classList.remove('opacity-50');
        }
    }, 1000);
}

async function resendOTP() {
    try {
        const res = await fetch('/resend-otp', { method: 'POST' });
        const data = await res.json();

        if (data.success) {
            alert('OTP Sent!');
            timerSeconds = 60;
            startTimer();
        }
    } catch {
        alert('Error sending OTP');
    }
}

window.onload = startTimer;
</script>

</body>
</html>